{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "NODE_ENV=production node scripts/ensure-site-config.mjs && tsx scripts/generate-pwa-icons.ts && tsx scripts/build-sw.ts",
    "build": "npm run typecheck && GALLERYKIT_TYPECHECKED=1 next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint",
    "typecheck": "npm run typecheck:app && npm run typecheck:scripts",
    "check:js-scripts": "node scripts/check-js-scripts.mjs",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed-admin.ts",
    "init": "tsx scripts/init-db.ts",
    "test:e2e": "env -u NO_COLOR npx playwright test",
    "e2e:seed": "tsx scripts/seed-e2e.ts",
    "lint:api-auth": "tsx scripts/check-api-auth.ts",
    "lint:action-origin": "tsx scripts/check-action-origin.ts",
    "typecheck:app": "node scripts/prepare-next-typegen.mjs && next typegen && tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck:scripts": "npm run check:js-scripts && tsc -p tsconfig.scripts.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "exif-reader": "^2.0.3",
    "focus-trap-react": "^12.0.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "mysql2": "^3.22.0",
    "next": "^16.2.3",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "p-queue": "^9.1.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "1.0.0-beta.9-e89174b",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "vitest": "^4.1.4"
  }
}
