# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=gallery
DB_PASSWORD=<change-me>
DB_NAME=gallery
# DB_SSL=false  # TLS is auto-enabled for non-localhost DB_HOST; set to "false" to disable

# Public URLs
BASE_URL=http://localhost:3000
# Optional absolute CDN origin/prefix for uploaded assets, for example:
# IMAGE_BASE_URL=https://cdn.example.com
# IMAGE_BASE_URL=https://cdn.example.com/gallery
# Set this before `next build` / Docker image build so Next.js can allow the remote host.
# Production values must be absolute HTTPS URLs without credentials, query strings, or hashes.
# IMAGE_BASE_URL=

# Admin Configuration
# If you ever seeded an environment from older checked-in examples, rotate both
# SESSION_SECRET and any bootstrap/admin credentials immediately. Historical git
# values must be treated as permanently compromised.
# Use either a strong plaintext bootstrap secret (16+ chars, not a common default)
# or a precomputed Argon2 hash that starts with $argon2.
ADMIN_PASSWORD=<generate-a-strong-admin-secret-or-argon2-hash>
# Optional plaintext password for Playwright admin flows when ADMIN_PASSWORD is hashed.
# E2E_ADMIN_PASSWORD=<plaintext-password-for-playwright-only>
# Remote admin E2E stays disabled unless you opt in explicitly.
# E2E_ADMIN_ENABLED=true
# E2E_ALLOW_REMOTE_ADMIN=true
SESSION_SECRET=<generate-with: openssl rand -hex 32>

# Image Processing
# SHARP_CONCURRENCY=10  # Upper bound for Sharp/libvips threads; runtime caps at CPU parallelism - 1
# QUEUE_CONCURRENCY=1  # Number of background image-processing jobs in this web process
# IMAGE_MAX_INPUT_PIXELS=268435456  # Max pixels for decompression bomb protection (default: 256M)
# IMAGE_MAX_INPUT_PIXELS_TOPIC=67108864  # Separate cap for topic image processing (default: 64M, smaller because topic images are 512x512)

# Audit Log
# AUDIT_LOG_RETENTION_DAYS=90  # How many days of audit log entries to keep (default: 90)

# Optional: cap total batch upload size (default: 2147483648 = 2 GiB)
# UPLOAD_MAX_TOTAL_BYTES=2147483648
# Optional: cap total files accepted per upload tracking window (default: 100)
# UPLOAD_MAX_FILES_PER_WINDOW=100

# Reverse Proxy
# Set to "true" when running behind nginx or another reverse proxy that sets
# X-Real-IP / X-Forwarded-For headers. Required for per-IP rate limiting to
# work correctly in the documented nginx/Docker deployment; without it, all
# requests are keyed as "unknown".
# TRUST_PROXY=true
# Number of trusted proxy hops from the right side of X-Forwarded-For.
# Keep 1 for the shipped nginx-only deployment; the app selects the client
# immediately before the trusted proxy suffix. Use 2 only for a known trusted
# chain such as CDN/LB -> nginx -> app. Admin same-origin checks intentionally
# fail closed if both Origin and Referer are missing.
# TRUSTED_PROXY_HOPS=1

# Health checks
# Default /api/health is liveness-only and does not reveal/probe DB readiness.
# Set to true only when your private orchestrator uses this endpoint as a
# readiness check.
# HEALTH_CHECK_DB=true
