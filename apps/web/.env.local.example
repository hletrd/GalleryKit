# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=gallery
DB_PASSWORD=password
DB_NAME=gallery
# DB_SSL=false  # TLS is auto-enabled for non-localhost DB_HOST; set to "false" to disable

# Admin Configuration
# Default password: "password"
ADMIN_PASSWORD=password
SESSION_SECRET=<generate-with: openssl rand -hex 32>

# Image Processing
# SHARP_CONCURRENCY=10  # Override Sharp thread pool size (default: CPU count - 2)
# IMAGE_MAX_INPUT_PIXELS=268435456  # Max pixels for decompression bomb protection (default: 256M)
