   608	export async function getTopicBySlug(slug: string) {
   609	    // Direct topic slugs are always ASCII-safe; aliases may contain CJK/emoji
   610	    if (/^[a-z0-9_-]+$/i.test(slug)) {
   611	        const [directMatch] = await db
   612	            .select({
   613	                slug: topics.slug,
   614	                label: topics.label,
   615	                order: topics.order,
   616	                image_filename: topics.image_filename,
   617	            })
   618	            .from(topics)
   619	            .where(eq(topics.slug, slug))
   620	            .limit(1);
   621	
   622	        if (directMatch) {
   623	            return directMatch;
   624	        }
   625	    }
   626	
   627	    // Always check aliases regardless of format — CJK/emoji aliases are valid
   628	    const [aliasMatch] = await db
   629	        .select({
   630	            slug: topics.slug,
   631	            label: topics.label,
   632	            order: topics.order,
   633	            image_filename: topics.image_filename,
   634	        })
   635	        .from(topicAliases)
   636	        .innerJoin(topics, eq(topicAliases.topicSlug, topics.slug))
   637	        .where(eq(topicAliases.alias, slug))
   638	        .limit(1);
   639	
   640	    return aliasMatch || null;
   641	}
