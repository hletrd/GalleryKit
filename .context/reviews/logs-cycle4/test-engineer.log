   227	export async function deleteTopic(slug: string) {
   228	    const t = await getTranslations('serverActions');
   229	    if (!(await isAdmin())) return { error: t('unauthorized') };
   230	
   231	    // Reject malformed input: if sanitization changes the value, the input
   232	    // contained control characters and must not silently proceed on a
   233	    // destructive operation (defense in depth — matches updateTopic pattern).
   234	    const cleanSlug = stripControlChars(slug) ?? '';
   235	    if (cleanSlug !== slug) {
   236	        return { error: t('invalidSlug') };
   237	    }
   238	    if (!cleanSlug || !isValidSlug(cleanSlug)) {
   239	        return { error: t('invalidSlug') };
   240	    }
   241	
   242	    try {
   243	        // Transaction prevents TOCTOU: image could be added between check and delete
   244	        let deletedImageFilename: string | null = null;
   245	        let deletedRows = 0;
   246	        await db.transaction(async (tx) => {
   247	            const headerImages = await tx.select({ id: images.id }).from(images).where(eq(images.topic, cleanSlug)).limit(1);
   248	            if (headerImages.length > 0) {
   249	                throw new Error('HAS_IMAGES');
   250	            }
   251	            const [topicRecord] = await tx.select({ image_filename: topics.image_filename }).from(topics).where(eq(topics.slug, cleanSlug)).limit(1);
   252	            deletedImageFilename = topicRecord?.image_filename ?? null;
   253	            const [delResult] = await tx.delete(topics).where(eq(topics.slug, cleanSlug));
   254	            deletedRows = delResult.affectedRows;
   255	        });
   256	        if (deletedRows === 0) {
   257	            return { error: t('topicNotFound') };
   258	        }
   259	        if (deletedImageFilename) {
   260	            await deleteTopicImage(deletedImageFilename);
   261	        }
   262	        // Log audit event only when the topic was actually deleted — avoids duplicate
   263	        // entries when concurrent deletion causes the transaction to delete 0 rows.
   264	        if (deletedRows > 0) {
   265	            const currentUser = await getCurrentUser();
   266	            logAuditEvent(currentUser?.id ?? null, 'topic_delete', 'topic', cleanSlug).catch(console.debug);
   267	        }
   268	
   269	        revalidateLocalizedPaths('/admin/categories', '/admin/dashboard', '/', `/${cleanSlug}`);
   270	        revalidateAllAppData();
   271	
   272	        return { success: true };
   273	    } catch (e) {
   274	         if (e instanceof Error && e.message === 'HAS_IMAGES') {
   275	             return { error: t('cannotDeleteCategoryWithImages') };
   276	         }
   277	         console.error('Failed to delete topic', e);
   278	         return { error: t('failedToDeleteTopic') };
   279	    }
   280	}
