   159	export async function deleteAdminUser(id: number) {
   160	    const t = await getTranslations('serverActions');
   161	    const currentUser = await getCurrentUser();
   162	    if (!currentUser) return { error: t('unauthorized') };
   163	
   164	    if (!Number.isInteger(id) || id <= 0) {
   165	        return { error: t('invalidUserId') };
   166	    }
   167	
   168	    // Prevent deleting self
   169	    if (currentUser.id === id) {
   170	        return { error: t('cannotDeleteSelf') };
   171	    }
   172	
   173	    // Serialize deletion through a DB advisory lock so concurrent requests
   174	    // cannot both observe "more than one admin" and remove the final two rows.
   175	    const conn = await connection.getConnection();
   176	    let lockAcquired = false;
   177	
   178	    try {
   179	        const [lockRows] = await conn.query<(RowDataPacket & { acquired: number })[]>(
   180	            "SELECT GET_LOCK('gallerykit_admin_delete', 5) AS acquired"
   181	        );
   182	        lockAcquired = (lockRows[0]?.acquired ?? 0) === 1;
   183	        if (!lockAcquired) {
   184	            throw new Error('DELETE_LOCK_TIMEOUT');
   185	        }
   186	
   187	        await conn.beginTransaction();
   188	        const [adminCountRows] = await conn.query<(RowDataPacket & { count: number })[]>(
   189	            'SELECT COUNT(*) AS count FROM admin_users'
   190	        );
   191	        if (Number(adminCountRows[0]?.count ?? 0) <= 1) {
   192	            throw new Error('LAST_ADMIN');
   193	        }
   194	
   195	        const [targetRows] = await conn.query<(RowDataPacket & { id: number })[]>(
   196	            'SELECT id FROM admin_users WHERE id = ? LIMIT 1',
   197	            [id]
   198	        );
   199	        if (!targetRows[0]) {
   200	            throw new Error('USER_NOT_FOUND');
   201	        }
   202	
   203	        await conn.query('DELETE FROM sessions WHERE user_id = ?', [id]);
   204	        const [deleteResult] = await conn.query<ResultSetHeader>(
   205	            'DELETE FROM admin_users WHERE id = ?',
   206	            [id]
   207	        );
   208	        if (Number(deleteResult.affectedRows ?? 0) === 0) {
   209	            throw new Error('USER_NOT_FOUND');
   210	        }
   211	
   212	        await conn.commit();
   213	        logAuditEvent(currentUser.id, 'user_delete', 'user', String(id)).catch(console.debug);
   214	        revalidateLocalizedPaths('/admin/dashboard', '/admin/users');
   215	        return { success: true };
   216	    } catch (e: unknown) {
   217	        await conn.rollback().catch(() => {});
   218	        if (e instanceof Error && e.message === 'DELETE_LOCK_TIMEOUT') {
   219	            return { error: t('failedToDeleteUser') };
   220	        }
   221	        if (e instanceof Error && e.message === 'LAST_ADMIN') {
   222	            return { error: t('cannotDeleteLastAdmin') };
   223	        }
   224	        if (e instanceof Error && e.message === 'USER_NOT_FOUND') {
   225	            return { error: t('userNotFound') };
   226	        }
   227	        console.error('Delete user failed', e);
   228	        return { error: t('failedToDeleteUser') };
   229	    } finally {
   230	        if (lockAcquired) {
   231	            await conn.query("SELECT RELEASE_LOCK('gallerykit_admin_delete')").catch(() => {});
   232	        }
   233	        conn.release();
   234	    }
   235	}

