   282	export async function createTopicAlias(topicSlug: string, alias: string) {
   283	    const t = await getTranslations('serverActions');
   284	    if (!(await isAdmin())) return { error: t('unauthorized') };
   285	
   286	    // Sanitize before validation — reject malformed input: if sanitization
   287	    // changes the value, the input contained control characters and must not
