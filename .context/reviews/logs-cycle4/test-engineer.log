   568	    // Fetch tags for all images in a single batched query (avoids N+1)
   569	    let imagesWithTags: (typeof groupImages[number] & { tags: { slug: string; name: string }[] })[];
   570	    if (groupImages.length > 0) {
   571	        const imageIds = groupImages.map(img => img.id);
   572	        const allTagRows = await db.select({
   573	            imageId: imageTags.imageId,
   574	            slug: tags.slug,
   575	            name: tags.name,
   576	        })
   577	        .from(imageTags)
   578	        .innerJoin(tags, eq(imageTags.tagId, tags.id))
   579	        .where(inArray(imageTags.imageId, imageIds));
   580	
   581	        const tagsByImage = new Map<number, { slug: string; name: string }[]>();
   582	        for (const t of allTagRows) {
   583	            const arr = tagsByImage.get(t.imageId) || [];
   584	            arr.push({ slug: t.slug, name: t.name });
   585	            tagsByImage.set(t.imageId, arr);
   586	        }
   587	
   588	        imagesWithTags = groupImages.map(img => ({
   589	            ...img,
   590	            tags: tagsByImage.get(img.id) || [],
   591	        }));
   592	    } else {
   593	        imagesWithTags = [];
   594	    }
   595	
   596	    // Increment view count only after the image fetch succeeds — avoids
   597	    // overcounting on DB errors during the image JOIN query.
   598	    if (options?.incrementViewCount !== false) {
   599	        bufferGroupViewCount(group.id);
   600	    }
   601	
   602	    return {
   603	        ...group,
   604	        images: imagesWithTags
   605	    };
   606	}
