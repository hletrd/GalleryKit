   375	                // characters (defense in depth — matches removeTagFromImage pattern).
   376	                if (cleanName !== trimmedName) continue;
   377	                if (!cleanName) continue;
   378	                let [tagRecord] = await tx.select({ id: tags.id }).from(tags).where(eq(tags.name, cleanName));
   379	                if (!tagRecord) {
   380	                    const slug = getTagSlug(cleanName);
   381	                    [tagRecord] = await tx.select({ id: tags.id }).from(tags).where(eq(tags.slug, slug));
   382	                }
   383	                if (tagRecord) {
   384	                    const [deleteResult] = await tx.delete(imageTags).where(and(eq(imageTags.imageId, imageId), eq(imageTags.tagId, tagRecord.id)));
   385	                    if (deleteResult.affectedRows > 0) removed++;
   386	                }
   387	            }
   388	        });
   389	    } catch (err) {
   390	        console.error('batchUpdateImageTags transaction failed:', err);
   391	        return { success: false, added: 0, removed: 0, warnings: [t('failedToAddTag')] };
   392	    }
