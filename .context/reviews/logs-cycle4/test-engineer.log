   339	export async function deleteTopicAlias(topicSlug: string, alias: string) {
   340	    const t = await getTranslations('serverActions');
   341	    if (!(await isAdmin())) return { error: t('unauthorized') };
   342	
   343	    // Reject malformed input: if sanitization changes the value, the input
   344	    // contained control characters and must not silently proceed on a
   345	    // destructive operation (defense in depth — matches updateTopic/deleteTopic pattern).
   346	    const cleanTopicSlug = stripControlChars(topicSlug) ?? '';
   347	    if (cleanTopicSlug !== topicSlug) {
   348	        return { error: t('invalidTopicSlug') };
   349	    }
   350	    if (!cleanTopicSlug || !isValidSlug(cleanTopicSlug)) {
   351	        return { error: t('invalidTopicSlug') };
   352	    }
   353	
   354	    // Sanitize before validation — reject malformed input (defense in depth)
   355	    const cleanAlias = stripControlChars(alias) ?? '';
   356	    if (cleanAlias !== alias) {
   357	        return { error: t('invalidAlias') };
   358	    }
   359	    // Permissive check to allow deleting legacy aliases
   360	    if (!cleanAlias || !isValidTopicAlias(cleanAlias)) {
   361	        return { error: t('invalidAlias') };
   362	    }
   363	
   364	    try {
   365	        const [delResult] = await db.delete(topicAliases).where(
   366	            and(
   367	                eq(topicAliases.alias, cleanAlias),
   368	                eq(topicAliases.topicSlug, cleanTopicSlug)
   369	            )
   370	        );
   371	        // Log audit event only when the alias was actually deleted — avoids
   372	        // duplicate entries when concurrent deletion causes the delete to affect 0 rows.
   373	        if (delResult.affectedRows > 0) {
   374	            const currentUser = await getCurrentUser();
   375	            logAuditEvent(currentUser?.id ?? null, 'topic_alias_delete', 'topic', cleanTopicSlug, undefined, { alias: cleanAlias }).catch(console.debug);
   376	        }
   377	    } catch (e) {
   378	        console.error('Failed to delete topic alias:', e);
   379	        return { error: t('failedToDeleteAlias') };
   380	    }
   381	
   382	    revalidateLocalizedPaths('/admin/categories', '/admin/tags', '/admin/dashboard', `/${cleanAlias}`, `/${cleanTopicSlug}`);
   383	    revalidateAllAppData();
   384	    return { success: true };
   385	}

