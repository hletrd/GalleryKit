    99	async function acquireImageProcessingClaim(jobId: number): Promise<PoolConnection | null> {
   100	    const lockConnection = await connection.getConnection();
   101	    try {
   102	        const [rows] = await lockConnection.query<(RowDataPacket & { acquired: number | null })[]>(
   103	            'SELECT GET_LOCK(?, 0) AS acquired',
   104	            [getProcessingLockName(jobId)],
   105	        );
   106	        if (rows[0]?.acquired === 1) {
   107	            return lockConnection;
   108	        }
   109	    } catch (err) {
   110	        lockConnection.release();
   111	        throw err;
   112	    }
   113	
   114	    lockConnection.release();
   115	    return null;
   116	}
