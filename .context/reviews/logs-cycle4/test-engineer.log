   312	export async function batchUpdateImageTags(
   313	    imageId: number,
   314	    addTagNames: string[],
   315	    removeTagNames: string[],
   316	): Promise<{ success: boolean; added: number; removed: number; warnings: string[] }> {
   317	    const t = await getTranslations('serverActions');
   318	    if (!(await isAdmin())) return { success: false, added: 0, removed: 0, warnings: [t('unauthorized')] };
   319	
   320	    if (!Number.isInteger(imageId) || imageId <= 0) {
   321	        return { success: false, added: 0, removed: 0, warnings: [t('invalidImageId')] };
   322	    }
   323	
   324	    // Limit tag array sizes to prevent DoS (matching batchAddTags pattern)
   325	    if (addTagNames.length > 100 || removeTagNames.length > 100) {
   326	        return { success: false, added: 0, removed: 0, warnings: [t('tooManyTags')] };
   327	    }
   328	
   329	    const warnings: string[] = [];
   330	    let added = 0;
   331	    let removed = 0;
   332	
   333	    try {
   334	        await db.transaction(async (tx) => {
   335	            // Add tags
   336	            for (const name of addTagNames) {
   337	                const trimmedName = name.trim();
   338	                const cleanName = stripControlChars(trimmedName) ?? '';
   339	                // Reject malformed input: skip tag names that contained control
   340	                // characters (defense in depth — matches addTagToImage pattern).
   341	                if (cleanName !== trimmedName) continue;
   342	                if (!cleanName) continue;
   343	                if (!isValidTagName(cleanName)) {
   344	                    warnings.push(t('invalidTagName') + `: "${cleanName}"`);
   345	                    continue;
   346	                }
   347	                const slug = getTagSlug(cleanName);
   348	                if (!isValidSlug(slug)) continue;
   349	                // Ensure tag exists
   350	                await tx.insert(tags).ignore().values({ name: cleanName, slug });
   351	                // Look up by exact name first, then fall back to slug — same pattern
   352	                // as addTagToImage and batchAddTags (see C3R-02).
   353	                let [tagRecord] = await tx.select().from(tags).where(eq(tags.name, cleanName));
   354	                if (!tagRecord) {
   355	                    [tagRecord] = await tx.select().from(tags).where(eq(tags.slug, slug));
   356	                }
   357	                if (tagRecord) {
   358	                    // Warn on tag slug collision (matching addTagToImage/batchAddTags pattern)
   359	                    if (tagRecord.name !== cleanName) {
   360	                        console.warn(`Tag slug collision: "${cleanName}" collides with existing "${tagRecord.name}" on slug "${slug}"`);
   361	                        warnings.push(t('tagSlugCollision', { newName: cleanName, existingName: tagRecord.name }));
   362	                    }
   363	                    const [tagInsertResult] = await tx.insert(imageTags).ignore().values({ imageId, tagId: tagRecord.id });
   364	                    if (tagInsertResult.affectedRows > 0) added++;
   365	                }
   366	            }
   367	
   368	            // Remove tags — look up by exact name first, then fall back to slug
   369	            // to avoid removing the wrong tag when slug collisions exist (same
   370	            // pattern as removeTagFromImage, see C38-01).
   371	            for (const name of removeTagNames) {
   372	                const trimmedName = name.trim();
