    42	/** Prune retry Maps to prevent unbounded growth from abandoned jobs. */
    43	function pruneRetryMaps(state: ProcessingQueueState) {
    44	    for (const map of [state.retryCounts, state.claimRetryCounts] as const) {
    45	        if (map.size <= MAX_RETRY_MAP_SIZE) continue;
    46	        const excess = map.size - MAX_RETRY_MAP_SIZE;
    47	        let evicted = 0;
    48	        for (const key of map.keys()) {
    49	            if (evicted >= excess) break;
    50	            map.delete(key);
    51	            evicted++;
    52	        }
    53	    }
