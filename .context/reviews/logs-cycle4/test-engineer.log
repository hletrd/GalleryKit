    21	function escapeCsvField(value: string): string {
    22	    // Strip null bytes, tab, and other control characters (except \r\n which are handled below)
    23	    // as defense-in-depth for legacy data stored before stripControlChars was added.
    24	    // \x09 (tab) is included: tabs in CSV values can cause column misalignment
    25	    // in strict parsers, even with double-quote wrapping (C9R2-F01).
    26	    value = value.replace(/[\x00-\x09\x0B\x0C\x0E-\x1F\x7F]/g, '');
    27	    // Strip carriage returns and newlines to prevent CSV injection via embedded line breaks
    28	    value = value.replace(/[\r\n]/g, ' ');
    29	    // Prefix formula injection characters with a single quote
    30	    if (value.match(/^[=+\-@\t]/)) {
    31	        value = "'" + value;
    32	    }
    33	    // Wrap in double quotes and escape embedded double quotes by doubling them
    34	    return '"' + value.replace(/"/g, '""') + '"';
    35	}
