   305	        return { error: t('invalidAliasFormat') };
   306	    }
   307	    if (isReservedTopicRouteSegment(cleanAlias)) {
   308	        return { error: t('reservedRouteSegment') };
   309	    }
   310	    if (await topicRouteSegmentExists(cleanAlias)) {
   311	        return { error: t('slugConflictsWithRoute') };
   312	    }
   313	
   314	    // US-007: Insert directly and catch ER_DUP_ENTRY to avoid TOCTOU race
   315	    try {
   316	        await db.insert(topicAliases).values({
   317	            alias: cleanAlias,
   318	            topicSlug: cleanTopicSlug
   319	        });
   320	
   321	        const currentUser = await getCurrentUser();
   322	        logAuditEvent(currentUser?.id ?? null, 'topic_alias_create', 'topic', cleanTopicSlug, undefined, { alias: cleanAlias }).catch(console.debug);
   323	
   324	        revalidateLocalizedPaths('/admin/categories', '/admin/dashboard', `/${cleanAlias}`, `/${cleanTopicSlug}`);
   325	        revalidateAllAppData();
