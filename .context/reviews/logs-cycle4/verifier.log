            setSheetState('peek');
        }
        prevIsOpenRef.current = isOpen;
    }, [isOpen]);

    const getTranslateY = useCallback((state: SheetState): string => {
        switch (state) {
            case 'collapsed':
                return 'calc(100% - 28px)'; // only drag handle visible
            case 'peek':
