    it('accepts CJK characters and emojis', () => {
        expect(isValidTopicAlias('my-alias')).toBe(true);
    });

    it('rejects slashes', () => {
        expect(isValidTopicAlias('a/b')).toBe(false);
        expect(isValidTopicAlias('a\\b')).toBe(false);
