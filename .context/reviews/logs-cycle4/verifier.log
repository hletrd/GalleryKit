    user_filename: varchar("user_filename", { length: 255 }),
    share_key: varchar("share_key", { length: 255 }).unique(),
    topic: varchar("topic", { length: 255 }).references(() => topics.slug, { onDelete: 'restrict' }).notNull(),

    // EXIF Data
