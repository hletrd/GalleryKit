    }

    // Single query: fetch group and check expiry atomically
    const [group] = await db.select().from(sharedGroups)
        .where(
            and(
                eq(sharedGroups.key, trimmedKey),
                or(
                    sql`${sharedGroups.expires_at} > NOW()`,
                    sql`${sharedGroups.expires_at} IS NULL`
                )
