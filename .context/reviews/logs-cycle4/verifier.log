async function topicRouteSegmentExists(segment: string): Promise<boolean> {
    const normalizedSegment = segment.trim();
    const [topicMatch] = await db.select({ slug: topics.slug })
        .from(topics)
        .where(eq(topics.slug, normalizedSegment))
        .limit(1);

    if (topicMatch) {
