    72	export const DEFAULT_IMAGE_SIZES = [640, 1536, 2048, 4096];
    73	
    74	/** Default OG image target size — used for social media previews. */
    75	export const DEFAULT_OG_TARGET_SIZE = 1536;
    76	
    77	/**
    78	 * Canonicalize an admin-provided image_sizes string into a sorted, deduped list.
    79	 * Returns null when the input is malformed or exceeds the supported list size.
    80	 */
    81	export function normalizeConfiguredImageSizes(sizesStr: string): string | null {
    82	    if (!sizesStr || !sizesStr.trim()) return null;
    83	
    84	    const rawParts = sizesStr.split(',').map((segment) => segment.trim());
    85	    if (rawParts.some((segment) => segment.length === 0)) {
    86	        return null;
    87	    }
    88	
    89	    const parsed = rawParts.map((segment) => Number(segment));
    90	    if (parsed.some((value) => !Number.isFinite(value) || value <= 0 || value > 10000)) {
    91	        return null;
    92	    }
    93	
    94	    const uniqueSorted = Array.from(new Set(parsed)).sort((a, b) => a - b);
    95	    if (uniqueSorted.length === 0 || uniqueSorted.length > MAX_IMAGE_SIZE_COUNT) {
    96	        return null;
    97	    }
    98	
    99	    return uniqueSorted.join(',');
   100	}
   101	
   102	/**
   103	 * Find the nearest configured image size to a target size.
   104	 * Used for OG images and thumbnails where a specific size is expected.
   105	 * Falls back to the largest size if no close match exists.
   106	 */
   107	export function findNearestImageSize(sizes: number[], targetSize: number): number {
   108	    if (sizes.length === 0) return DEFAULT_IMAGE_SIZES[DEFAULT_IMAGE_SIZES.length - 1]; // fallback — no sizes configured
   109	    let nearest = sizes[0];
   110	    let minDiff = Math.abs(sizes[0] - targetSize);
   111	    for (let i = 1; i < sizes.length; i++) {
   112	        const diff = Math.abs(sizes[i] - targetSize);
   113	        if (diff < minDiff) {
   114	            minDiff = diff;
   115	            nearest = sizes[i];
   116	        }
   117	    }
   118	    return nearest;
   119	}
   120	
   121	/**
   122	 * Parse image_sizes string into sorted number array.
   123	 * Returns DEFAULT_IMAGE_SIZES if the input is empty or invalid.
   124	 */
   125	export function parseImageSizes(sizesStr: string): number[] {
   126	    const normalized = normalizeConfiguredImageSizes(sizesStr);
   127	    if (!normalized) return DEFAULT_IMAGE_SIZES;
   128	    return normalized.split(',').map((value) => Number(value));
   129	}

