   326	        purgeOldBuckets().catch(err => console.debug('purgeOldBuckets failed:', err));
   327	        purgeOldAuditLog().catch(err => console.debug('purgeOldAuditLog failed:', err));
   328	        if (state.gcInterval) clearInterval(state.gcInterval);
   329	        state.gcInterval = setInterval(() => {
   330	            purgeExpiredSessions();
   331	            purgeOldBuckets().catch(err => console.debug('purgeOldBuckets failed:', err));
   332	            purgeOldAuditLog().catch(err => console.debug('purgeOldAuditLog failed:', err));
