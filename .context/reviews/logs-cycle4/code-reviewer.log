     1	/**
     2	 * MinIO Storage Backend
     3	 *
     4	 * Extends the S3 backend with MinIO-specific defaults.
     5	 * MinIO is fully S3-compatible, so we just configure the endpoint
     6	 * and force path-style access.
     7	 *
     8	 * Configuration via environment variables (same as S3, plus):
     9	 * - MINIO_ENDPOINT: MinIO server URL (e.g. http://minio:9000)
    10	 * - MINIO_ACCESS_KEY_ID: MinIO access key
    11	 * - MINIO_SECRET_ACCESS_KEY: MinIO secret key
    12	 * - MINIO_BUCKET: Bucket name (default: gallery)
    13	 * - MINIO_PUBLIC_URL: Optional public URL (e.g. https://minio.example.com/gallery)
    14	 *
    15	 * Falls back to S3_* env vars if MINIO_* vars are not set.
    16	 */
    17	
    18	import { S3StorageBackend } from './s3';
    19	import type { StorageBackend } from './types';
    20	
    21	interface MinIOStorageConfig {
    22	    endpoint?: string;
    23	    region?: string;
    24	    accessKeyId?: string;
    25	    secretAccessKey?: string;
    26	    bucket?: string;
    27	    publicUrl?: string;
    28	}
    29	
    30	function getMinIOConfigFromEnv(): MinIOStorageConfig {
    31	    return {
    32	        endpoint: process.env.MINIO_ENDPOINT?.trim() || process.env.S3_ENDPOINT?.trim(),
    33	        region: process.env.MINIO_REGION?.trim() || process.env.S3_REGION?.trim() || 'us-east-1',
    34	        accessKeyId: process.env.MINIO_ACCESS_KEY_ID?.trim() || process.env.S3_ACCESS_KEY_ID?.trim() || '',
    35	        secretAccessKey: process.env.MINIO_SECRET_ACCESS_KEY?.trim() || process.env.S3_SECRET_ACCESS_KEY?.trim() || '',
    36	        bucket: process.env.MINIO_BUCKET?.trim() || process.env.S3_BUCKET?.trim() || 'gallery',
    37	        publicUrl: process.env.MINIO_PUBLIC_URL?.trim() || process.env.S3_PUBLIC_URL?.trim(),
    38	    };
    39	}
    40	
    41	export class MinIOStorageBackend extends S3StorageBackend implements StorageBackend {
    42	    constructor(config?: Partial<MinIOStorageConfig>) {
    43	        const envConfig = getMinIOConfigFromEnv();
    44	        const resolved = { ...envConfig, ...config };
    45	        // MinIO always uses path-style addressing
    46	        super(
    47	            { ...resolved, forcePathStyle: true },
    48	            'minio',
    49	        );
    50	    }
    51	}

