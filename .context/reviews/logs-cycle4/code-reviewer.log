   289	export async function deleteGroupShareLink(groupId: number) {
   290	    const t = await getTranslations('serverActions');
   291	    if (!(await isAdmin())) return { error: t('unauthorized') };
   292	
   293	    if (!Number.isInteger(groupId) || groupId <= 0) {
   294	        return { error: t('invalidGroupId') };
   295	    }
   296	
   297	    // Fetch group key before deletion for cache revalidation
   298	    const [group] = await db.select({ key: sharedGroups.key }).from(sharedGroups).where(eq(sharedGroups.id, groupId));
