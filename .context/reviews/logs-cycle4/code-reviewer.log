   205	            'DELETE FROM admin_users WHERE id = ?',
   206	            [id]
   207	        );
   208	        if (Number(deleteResult.affectedRows ?? 0) === 0) {
   209	            throw new Error('USER_NOT_FOUND');
   210	        }
   211	
   212	        await conn.commit();
   213	        logAuditEvent(currentUser.id, 'user_delete', 'user', String(id)).catch(console.debug);
   214	        revalidateLocalizedPaths('/admin/dashboard', '/admin/users');
   215	        return { success: true };
   216	    } catch (e: unknown) {
   217	        await conn.rollback().catch(() => {});
