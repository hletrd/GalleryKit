    58	export function containsDangerousSql(input: string): boolean {
    59	    const sanitized = stripSqlCommentsAndLiterals(input);
    60	    return DANGEROUS_SQL_PATTERNS.some((pattern) => pattern.test(sanitized));
    61	}

