   589	            ...img,
   590	            tags: tagsByImage.get(img.id) || [],
   591	        }));
   592	    } else {
   593	        imagesWithTags = [];
   594	    }
   595	
   596	    // Increment view count only after the image fetch succeeds — avoids
   597	    // overcounting on DB errors during the image JOIN query.
   598	    if (options?.incrementViewCount !== false) {
   599	        bufferGroupViewCount(group.id);
   600	    }
   601	
   602	    return {
   603	        ...group,
   604	        images: imagesWithTags
   605	    };
   606	}
