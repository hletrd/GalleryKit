   643	// PRIVACY: SearchResult omits filename_webp and filename_avif to minimize
   644	// internal filename exposure to unauthenticated users. filename_jpeg is
   645	// retained because the search UI needs it for thumbnail rendering.
   646	interface SearchResult {
   647	    id: number;
   648	    title: string | null;
   649	    description: string | null;
   650	    filename_jpeg: string;
   651	    width: number;
   652	    height: number;
   653	    topic: string;
   654	    camera_model: string | null;
   655	    capture_date: string | null;
   656	}
   657	
   658	export type { SearchResult };
   659	
   660	export async function searchImages(query: string, limit: number = 20): Promise<SearchResult[]> {
   661	    if (!query || query.trim().length === 0) return [];
   662	    if (query.length > 200) return [];
   663	    if (limit <= 0) return [];
   664	    const effectiveLimit = Math.min(Math.max(limit, 1), 100);
   665	
   666	    const escaped = query.trim().replace(/[%_\\]/g, '\\$&');
   667	    const searchTerm = `%${escaped}%`;
   668	
   669	    // PRIVACY: Omit filename_webp and filename_avif from public search results
   670	    // to minimize internal filename exposure. filename_jpeg is needed for thumbnails.
   671	    const searchFields = {
   672	        id: images.id, title: images.title, description: images.description,
   673	        filename_jpeg: images.filename_jpeg, width: images.width, height: images.height,
   674	        topic: images.topic, camera_model: images.camera_model,
   675	        capture_date: images.capture_date,
   676	    };
   677	
   678	    // Run main query first; only query tags if we need more results (saves a connection)
   679	    const results = await db.select(searchFields).from(images)
   680	        .where(and(
   681	            eq(images.processed, true),
   682	            or(
   683	                like(images.title, searchTerm),
   684	                like(images.description, searchTerm),
   685	                like(images.camera_model, searchTerm),
   686	                like(images.topic, searchTerm),
   687	            )
   688	        ))
   689	        .orderBy(desc(images.created_at), desc(images.id))
   690	        .limit(effectiveLimit);
   691	
   692	    // Only search tags if main results are insufficient; limit to remaining slots.
   693	    // Exclude IDs already found by the main query so tag-result slots aren't
   694	    // wasted on duplicates (especially with small effectiveLimit values).
   695	    const remainingLimit = effectiveLimit - results.length;
   696	    const mainIds = results.map(r => r.id);
   697	    const tagConditions = [eq(images.processed, true), like(tags.name, searchTerm)];
   698	    if (mainIds.length > 0) {
   699	        tagConditions.push(notInArray(images.id, mainIds));
   700	    }
   701	    const tagResults = remainingLimit <= 0 ? [] : await db.select(searchFields)
   702	        .from(images)
   703	        .innerJoin(imageTags, eq(images.id, imageTags.imageId))
   704	        .innerJoin(tags, eq(imageTags.tagId, tags.id))
   705	        .where(and(...tagConditions))
   706	        .groupBy(
   707	            images.id,
   708	            images.title,
   709	            images.description,
   710	            images.filename_jpeg,
   711	            images.width,
   712	            images.height,
   713	            images.topic,
   714	            images.camera_model,
   715	            images.capture_date,
   716	        )
   717	        .orderBy(desc(images.created_at), desc(images.id))
   718	        .limit(remainingLimit);
   719	
   720	    const seen = new Set<number>();
   721	    const combined: SearchResult[] = [];
   722	    for (const r of [...results, ...tagResults]) {
   723	        if (!seen.has(r.id)) {
   724	            seen.add(r.id);
   725	            combined.push(r);
   726	        }
   727	    }
   728	
   729	    return combined.slice(0, effectiveLimit);
   730	}
