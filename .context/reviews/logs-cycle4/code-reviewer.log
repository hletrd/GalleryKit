   282	    logAuditEvent(currentUser?.id ?? null, 'share_revoke', 'image', String(imageId), undefined, {
   283	        keyFingerprint: getShareKeyFingerprint(oldShareKey),
   284	        keyLength: oldShareKey.length,
   285	    }).catch(console.debug);
   286	    return { success: true };
   287	}
