   732	/** Lightweight query for sitemap: only id + created_at, no JOINs, no TEXT columns */
   733	export async function getImageIdsForSitemap(limit: number = 24000) {
   734	    const safeLimit = Math.min(Math.max(limit, 1), 50000);
   735	    return db.select({
   736	        id: images.id,
   737	        created_at: images.created_at,
   738	    })
   739	    .from(images)
   740	    .where(eq(images.processed, true))
   741	    .orderBy(desc(images.created_at))
   742	    .limit(safeLimit);
   743	}
