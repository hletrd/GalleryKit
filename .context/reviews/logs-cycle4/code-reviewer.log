   112	/**
   113	 * Switch the storage backend type. Called when admin changes the setting.
   114	 * Disposes the old backend and creates a new one. Rolls back on failure.
   115	 */
   116	export async function switchStorageBackend(type: StorageBackendType): Promise<void> {
   117	    const state = getGlobalState();
   118	
   119	    if (state.type === type && state.initialized) {
   120	        return; // No change needed
   121	    }
   122	
   123	    // Validate credentials before attempting the switch
   124	    validateStorageCredentials(type);
   125	
   126	    // Save old backend for rollback on failure
   127	    const oldBackend = state.backend;
   128	    const oldType = state.type;
   129	    const wasInitialized = state.initialized;
   130	
   131	    // NOTE: Do NOT dispose the old backend until the new one is confirmed working.
   132	    // If we dispose first and the new backend fails to init, the rollback would
   133	    // restore a destroyed backend (e.g., S3Client.destroy() has been called),
   134	    // causing all subsequent storage operations to fail until server restart.
   135	
   136	    let newBackend: StorageBackend;
   137	    switch (type) {
   138	        case 'minio': {
   139	            const { MinIOStorageBackend } = await import('./minio');
   140	            newBackend = new MinIOStorageBackend();
   141	            break;
   142	        }
   143	        case 's3': {
   144	            const { S3StorageBackend } = await import('./s3');
   145	            newBackend = new S3StorageBackend(undefined, 's3');
   146	            break;
   147	        }
   148	        case 'local':
   149	        default:
   150	            newBackend = new LocalStorageBackend();
   151	            break;
   152	    }
   153	
   154	    state.backend = newBackend;
   155	    state.type = type;
   156	    state.initialized = false;
   157	    state.initPromise = null;
   158	
   159	    // Initialize the new backend — roll back on failure
   160	    try {
   161	        await getStorage();
   162	        console.log(`[Storage] Switched to ${type} backend`);
   163	        // New backend is confirmed working — now safe to dispose the old one
   164	        if (oldBackend.dispose) {
   165	            await oldBackend.dispose().catch(err => {
   166	                console.warn('[Storage] Failed to dispose old backend:', err);
   167	            });
   168	        }
   169	    } catch (err) {
   170	        // Roll back to the old backend so the app remains functional
   171	        console.error(`[Storage] Failed to initialize ${type} backend, rolling back to ${oldType}:`, err);
   172	        state.backend = oldBackend;
   173	        state.type = oldType;
   174	        state.initialized = wasInitialized;
   175	        state.initPromise = null;
   176	        throw err;
   177	    }
   178	}
