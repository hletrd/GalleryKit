   441	function cleanString(val: unknown): string | null {
   442	    if (val === undefined || val === null) return null;
   443	    const s = String(val).trim();
   444	    if (s.length === 0) return null;
   445	    // Only reject literal 'undefined'/'null' strings when the input was not
   446	    // already a string — prevents dropping legitimate EXIF metadata that
   447	    // happens to be the word "null" or "undefined".
   448	    if (typeof val !== 'string' && (s.toLowerCase() === 'undefined' || s.toLowerCase() === 'null')) return null;
   449	    return s;
   450	}
   451	
   452	function cleanNumber(val: unknown): number | null {
   453	    if (val === undefined || val === null) return null;
   454	    const v = Array.isArray(val) ? val[0] : val; // Handle arrays like [100]
   455	    const n = Number(v);
   456	    return !Number.isFinite(n) ? null : n;
   457	}
   458	
   459	export function extractExifForDb(exifData: ExifDataRaw) {
   460	    // exif-reader returns top-level objects: image, thumbnail, exif, gps, interloper
   461	    const exifParams = exifData.exif || exifData.Photo || {};
   462	    const imageParams = exifData.image || exifData.Image || {};
   463	    const gpsParams = exifData.gps || exifData.GPSInfo || {};
   464	
   465	    const fNumber = exifParams.FNumber;
   466	    const iso = exifParams.ISO ?? exifParams.ISOSpeedRatings;
   467	    const exposureTime = exifParams.ExposureTime;
   468	
   469	    const dateTimeOriginal = exifParams.DateTimeOriginal;
   470	
   471	    let latitude: number | null = null;
   472	    let longitude: number | null = null;
   473	
   474	    if (gpsParams) {
   475	        const convertDMSToDD = (dms: number[], ref: string, maxDegrees: number) => {
   476	            if (!dms || dms.length < 3) return null;
   477	            if (dms[0] < 0 || dms[0] > maxDegrees || dms[1] < 0 || dms[1] >= 60 || dms[2] < 0 || dms[2] >= 60) return null;
   478	            let dd = dms[0] + dms[1] / 60 + dms[2] / 3600;
   479	            if (ref === 'S' || ref === 'W') {
   480	                dd = dd * -1;
   481	            }
   482	            if (Math.abs(dd) > maxDegrees) return null;
   483	            return dd;
   484	        };
   485	
   486	        if (gpsParams.GPSLatitude && gpsParams.GPSLatitudeRef) {
   487	            latitude = convertDMSToDD(gpsParams.GPSLatitude, gpsParams.GPSLatitudeRef, 90);
   488	        }
   489	        if (gpsParams.GPSLongitude && gpsParams.GPSLongitudeRef) {
   490	            longitude = convertDMSToDD(gpsParams.GPSLongitude, gpsParams.GPSLongitudeRef, 180);
   491	        }
   492	    }
   493	
   494	    return {
   495	        capture_date: parseExifDateTime(dateTimeOriginal) ?? undefined,
   496	        camera_model: cleanString(imageParams.Model) || undefined,
   497	        lens_model: cleanString(exifParams.LensModel),
   498	        iso: cleanNumber(iso),
   499	        f_number: cleanNumber(fNumber),
   500	        exposure_time: cleanString(exposureTime),
   501	        focal_length: cleanNumber(exifParams.FocalLength),
   502	        latitude,
   503	        longitude,
   504	        color_space: (() => {
   505	            // Colorspace tag (0xA001): 1 = sRGB, 65535 = Uncalibrated (often Adobe RGB or P3)
   506	            const cs = exifParams.ColorSpace;
   507	            if (cs === 1) return 'sRGB';
   508	
   509	            // 65535 = Uncalibrated; actual profile determined by ICC parsing.
   510	            if (cs === 65535) {
   511	               return 'Uncalibrated';
   512	            }
   513	
   514	            return null;
   515	        })(),
   516	
   517	        white_balance: (() => {
   518	            const wb = exifParams.WhiteBalance;
   519	            if (wb === 0) return 'Auto';
   520	            if (wb === 1) return 'Manual';
   521	            return null;
   522	        })(),
   523	
   524	        metering_mode: (() => {
   525	            const mm = exifParams.MeteringMode;
   526	            const modes: Record<number, string> = {
   527	                0: 'Unknown', 1: 'Average', 2: 'Center-weighted', 3: 'Spot',
   528	                4: 'Multi-spot', 5: 'Multi-segment', 6: 'Partial'
   529	            };
   530	            return (typeof mm === 'number' ? modes[mm] : null) ?? null;
   531	        })(),
   532	
   533	        exposure_compensation: (() => {
   534	            const ec = exifParams.ExposureBiasValue ?? exifParams.ExposureCompensation;
   535	            if (ec === undefined || ec === null) return null;
   536	            const val = Number(ec);
   537	            if (!Number.isFinite(val)) return null;
   538	            if (val === 0) return '0 EV';
   539	            return `${val > 0 ? '+' : ''}${val.toFixed(1)} EV`;
   540	        })(),
   541	
   542	        exposure_program: (() => {
   543	            const ep = exifParams.ExposureProgram;
   544	            const programs: Record<number, string> = {
   545	                0: 'Not Defined', 1: 'Manual', 2: 'Program AE', 3: 'Aperture Priority',
   546	                4: 'Shutter Priority', 5: 'Creative', 6: 'Action', 7: 'Portrait', 8: 'Landscape'
   547	            };
   548	            return (typeof ep === 'number' ? programs[ep] : null) ?? null;
   549	        })(),
   550	
   551	        flash: (() => {
   552	            const f = exifParams.Flash;
   553	            if (f === undefined || f === null) return null;
   554	            const val = typeof f === 'number' ? f : Number(f);
   555	            if (!Number.isFinite(val)) return null;
   556	            // Bit 0: fired, Bits 1-2: return, Bits 3-4: mode
   557	            const fired = (val & 0x01) !== 0;
   558	            const mode = (val >> 3) & 0x03;
   559	            if (mode === 2) return fired ? 'Auto, Fired' : 'Auto, Not Fired';
   560	            if (mode === 1) return 'Forced On';
   561	            if (mode === 3) return 'Forced Off';
   562	            return fired ? 'Fired' : 'Not Fired';
   563	        })(),
   564	
   565	        // Set from Sharp metadata in saveOriginalAndGetMetadata
   566	        bit_depth: null as number | null,
   567	    };
   568	}

