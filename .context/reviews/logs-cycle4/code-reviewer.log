    50	const VALIDATORS: Record<GallerySettingKey, (value: string) => boolean> = {
    51	    image_quality_webp: (v) => { const n = Number(v); return Number.isFinite(n) && n >= 1 && n <= 100; },
    52	    image_quality_avif: (v) => { const n = Number(v); return Number.isFinite(n) && n >= 1 && n <= 100; },
    53	    image_quality_jpeg: (v) => { const n = Number(v); return Number.isFinite(n) && n >= 1 && n <= 100; },
    54	    image_sizes: (v) => normalizeConfiguredImageSizes(v) !== null,
    55	    strip_gps_on_upload: (v) => v === 'true' || v === 'false',
    56	};
    57	
    58	/** Validate a setting value. Returns true if valid. */
    59	export function isValidSettingValue(key: GallerySettingKey, value: string): boolean {
    60	    const validator = VALIDATORS[key];
    61	    return validator ? validator(value) : false;
    62	}
    63	
    64	/** Get all defaults (for UI display). */
    65	export function getSettingDefaults(): Record<GallerySettingKey, string> {
