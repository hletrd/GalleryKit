   299	            filename_original: images.filename_original,
   300	            filename_webp: images.filename_webp,
   301	            filename_avif: images.filename_avif,
   302	            filename_jpeg: images.filename_jpeg,
   303	            width: images.width,
   304	        }).from(images).where(eq(images.processed, false));
   305	        for (const image of pending) {
   306	            enqueueImageProcessing({
   307	                id: image.id,
   308	                filenameOriginal: image.filename_original,
   309	                filenameWebp: image.filename_webp,
   310	                filenameAvif: image.filename_avif,
   311	                filenameJpeg: image.filename_jpeg,
   312	                width: image.width,
   313	            });
   314	
   315	        }
   316	        state.bootstrapped = true;
   317	
