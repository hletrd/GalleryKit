    36	
    37	export function stripSqlCommentsAndLiterals(input: string): string {
    38	    // Extract inner content from MySQL conditional comments (/*!ddddd ... */)
    39	    // before stripping. These are EXECUTED by MySQL when server version >= ddddd,
    40	    // so their content must be scanned. Replace the entire conditional comment
    41	    // with its inner statement text so the dangerous-SQL patterns can match it.
    42	    const withoutConditionals = input.replace(/\/\*!(\d{5,6})\s*([\s\S]*?)\*\//g, (_, _version, inner) => inner);
    43	
    44	    const withoutComments = withoutConditionals.replace(/\/\*.*?\*\//gs, '');
    45	
    46	    return [
    47	        /'(?:''|\\.|[^'\\])*'/gs,
    48	        /"(?:\"\"|\\.|[^"\\])*"/gs,
    49	        /`(?:``|\\.|[^`\\])*`/gs,
    50	        // Hex literals: 0x followed by hex digits (can encode malicious data for INSERT)
    51	        /0x[0-9a-fA-F]+/g,
    52	        // Binary literals: b'...' or 0b... (MySQL bit-value literals)
    53	        /b'[01]+'/g,
    54	        /0b[01]+/g,
    55	    ].reduce((acc, pattern) => maskMatches(acc, pattern), withoutComments);
    56	}
