    35	        if (!dirsPromise) {
    36	            dirsPromise = Promise.all(
    37	                REQUIRED_DIRS.map(dir => fs.mkdir(path.join(UPLOAD_ROOT, dir), { recursive: true })),
    38	            ).then(() => {}).catch((e) => {
    39	                dirsPromise = null;
    40	                throw e;
    41	            });
    42	        }
    43	        return dirsPromise;
    44	    }
