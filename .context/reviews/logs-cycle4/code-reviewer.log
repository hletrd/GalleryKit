     1	export type QueueShutdownLike = {
     2	    pause: () => void;
     3	    clear: () => void;
     4	    onPendingZero: () => Promise<void>;
     5	};
     6	
     7	export type QueueShutdownStateLike = {
     8	    enqueued: Set<number>;
     9	    shuttingDown: boolean;
    10	    shutdownPromise?: Promise<void>;
    11	    gcInterval?: ReturnType<typeof setInterval>;
    12	};
    13	
    14	export async function drainProcessingQueueForShutdown(
    15	    state: QueueShutdownStateLike,
    16	    queue: QueueShutdownLike,
    17	) {
    18	    if (state.shutdownPromise) {
    19	        await state.shutdownPromise;
    20	        return;
    21	    }
    22	
    23	    state.shuttingDown = true;
    24	    state.shutdownPromise = (async () => {
    25	        if (state.gcInterval) {
    26	            clearInterval(state.gcInterval);
    27	            state.gcInterval = undefined;
    28	        }
    29	
    30	        queue.pause();
    31	        queue.clear();
    32	        state.enqueued.clear();
    33	        await queue.onPendingZero();
    34	    })();
    35	
    36	    await state.shutdownPromise;
    37	}

