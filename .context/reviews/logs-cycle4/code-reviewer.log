    29	function pruneShareRateLimit() {
    30	    const now = Date.now();
    31	    for (const [key, entry] of shareRateLimit) {
    32	        if (entry.resetAt <= now) shareRateLimit.delete(key);
    33	    }
    34	    if (shareRateLimit.size > SHARE_RATE_LIMIT_MAX_KEYS) {
    35	        const excess = shareRateLimit.size - SHARE_RATE_LIMIT_MAX_KEYS;
    36	        let evicted = 0;
    37	        for (const key of shareRateLimit.keys()) {
    38	            if (evicted >= excess) break;
    39	            shareRateLimit.delete(key);
    40	            evicted++;
