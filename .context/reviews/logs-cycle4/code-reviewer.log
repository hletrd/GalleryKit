   303	                            const recLen = Math.min(icc.readUInt32BE(dataOffset + 16), 1024);
   304	                            const strStart = dataOffset + recOffset;
   305	                            const strEnd = strStart + recLen;
   306	                            if (strEnd > iccLen || strStart >= strEnd) break;
   307	                            const str = icc.subarray(strStart, strEnd).toString('utf16le');
