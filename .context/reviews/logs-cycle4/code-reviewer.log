    47	function checkShareRateLimit(ip: string): boolean {
    48	    pruneShareRateLimit();
    49	    const now = Date.now();
    50	    const entry = shareRateLimit.get(ip);
    51	    if (!entry || entry.resetAt <= now) {
    52	        shareRateLimit.set(ip, { count: 1, resetAt: now + SHARE_RATE_LIMIT_WINDOW_MS });
    53	    } else {
    54	        entry.count++;
    55	    }
    56	    // Return true if OVER the limit (rate-limited)
    57	    const currentEntry = shareRateLimit.get(ip)!;
    58	    return currentEntry.count > SHARE_MAX_PER_WINDOW;
    59	}
