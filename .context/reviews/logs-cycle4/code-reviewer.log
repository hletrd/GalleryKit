   131	            try {
   132	                const res = await uploadImages(formData);
   133	                if (res?.error) {
   134	                    console.error(`Failed to upload ${file.name}:`, res.error);
   135	                    failedFiles.push(file);
   136	                } else {
   137	                    successCount++;
   138	                    if (res?.replaced?.length) {
