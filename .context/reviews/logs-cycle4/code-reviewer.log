   339	export interface ImageQualitySettings {
   340	    webp?: number;
   341	    avif?: number;
   342	    jpeg?: number;
   343	}
   344	
   345	export async function processImageFormats(
   346	    inputPath: string,
   347	    filenameWebp: string,
   348	    filenameAvif: string,
   349	    filenameJpeg: string,
   350	    baseWidth: number, // The width from metadata
   351	    quality?: ImageQualitySettings, // Admin-configured quality overrides
   352	    sizes: number[] = DEFAULT_OUTPUT_SIZES, // Admin-configured output sizes
   353	) {
   354	    // Use file path so Sharp can mmap/stream instead of buffering on the heap.
   355	    const image = sharp(inputPath, { limitInputPixels: maxInputPixels });
   356	    const qualityWebp = quality?.webp ?? 90;
   357	    const qualityAvif = quality?.avif ?? 85;
   358	    const qualityJpeg = quality?.jpeg ?? 90;
   359	
   360	    const generateForFormat = async (
   361	        format: 'webp' | 'avif' | 'jpeg',
   362	        dir: string,
   363	        baseFilename: string,
   364	    ) => {
   365	        const ext = path.extname(baseFilename);
   366	        const name = path.basename(baseFilename, ext);
   367	        let lastRendered: { resizeWidth: number; filePath: string } | null = null;
   368	
   369	        for (const size of sizes) {
   370	            // Don't upscale if original is smaller.
   371	            const resizeWidth = baseWidth < size ? baseWidth : size;
   372	
   373	            // Suffix based filename: id_2048.webp
   374	            const sizedFilename = `${name}_${size}${ext}`;
   375	            const outputPath = path.join(dir, sizedFilename);
   376	
   377	            if (lastRendered && lastRendered.resizeWidth === resizeWidth) {
   378	                await fs.copyFile(lastRendered.filePath, outputPath);
   379	            } else {
   380	                const sharpInstance = image.clone().resize({ width: resizeWidth }).keepIccProfile();
   381	
   382	                if (format === 'webp') {
   383	                    await sharpInstance.webp({ quality: qualityWebp }).toFile(outputPath);
   384	                } else if (format === 'avif') {
   385	                    await sharpInstance.avif({ quality: qualityAvif }).toFile(outputPath);
   386	                } else {
   387	                    await sharpInstance.jpeg({ quality: qualityJpeg }).toFile(outputPath);
   388	                }
   389	
   390	                lastRendered = { resizeWidth, filePath: outputPath };
   391	            }
   392	
   393	            // The largest configured size serves as the "base" filename to satisfy existing schema.
   394	            // Use atomic rename via .tmp file to eliminate the window where the base
   395	            // filename doesn't exist (prevents 404s during concurrent reads).
   396	            if (size === sizes[sizes.length - 1]) {
   397	                const basePath = path.join(dir, baseFilename);
   398	                const tmpPath = basePath + '.tmp';
   399	                try {
   400	                    await fs.link(outputPath, tmpPath);
   401	                    await fs.rename(tmpPath, basePath);
   402	                } catch {
   403	                    // Fallback: copy to tmp then rename (covers cross-device or link failure)
   404	                    await fs.copyFile(outputPath, tmpPath).catch(() => {});
   405	                    try {
   406	                        await fs.rename(tmpPath, basePath);
   407	                    } catch {
   408	                        // Final fallback: direct copy if rename fails
   409	                        await fs.copyFile(outputPath, basePath);
   410	                    }
   411	                } finally {
   412	                    await fs.unlink(tmpPath).catch(() => {});
   413	                }
   414	            }
   415	        }
   416	    };
   417	
   418	    // Generate all three formats in parallel
   419	    await Promise.all([
   420	        generateForFormat('webp', UPLOAD_DIR_WEBP, filenameWebp),
   421	        generateForFormat('avif', UPLOAD_DIR_AVIF, filenameAvif),
   422	        generateForFormat('jpeg', UPLOAD_DIR_JPEG, filenameJpeg),
   423	    ]);
   424	
   425	    // Verify all three output format base files are not empty
   426	    try {
   427	        const [webpStats, avifStats, jpegStats] = await Promise.all([
   428	            fs.stat(path.join(UPLOAD_DIR_WEBP, filenameWebp)),
   429	            fs.stat(path.join(UPLOAD_DIR_AVIF, filenameAvif)),
   430	            fs.stat(path.join(UPLOAD_DIR_JPEG, filenameJpeg)),
   431	        ]);
   432	        if (webpStats.size === 0) throw new Error('Generated WebP file is empty');
   433	        if (avifStats.size === 0) throw new Error('Generated AVIF file is empty');
   434	        if (jpegStats.size === 0) throw new Error('Generated JPEG file is empty');
   435	    } catch (e) {
   436	        console.error('File verification failed:', e);
   437	        throw new Error('Image processing failed: generated file could not be verified');
   438	    }
   439	}
