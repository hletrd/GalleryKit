   386	export async function deleteImages(ids: number[]) {
   387	    const t = await getTranslations('serverActions');
   388	    if (!(await isAdmin())) {
   389	        return { error: t('unauthorized') };
   390	    }
   391	
   392	    if (!Array.isArray(ids) || ids.length === 0) {
   393	        return { error: t('noImagesSelected') };
   394	    }
   395	
   396	    // Limit batch size to prevent DoS
   397	    if (ids.length > 100) {
   398	        return { error: t('tooManyImages') };
   399	    }
   400	
   401	    // Validate all IDs upfront
   402	    for (const id of ids) {
   403	        if (!Number.isInteger(id) || id <= 0) {
   404	            return { error: t('invalidImageId') };
   405	        }
   406	    }
   407	
   408	    // Fetch all images in one query — select only needed columns
   409	    const imageRecords = await db.select({
   410	        id: images.id,
   411	        topic: images.topic,
   412	        filename_original: images.filename_original,
   413	        filename_webp: images.filename_webp,
   414	        filename_avif: images.filename_avif,
   415	        filename_jpeg: images.filename_jpeg,
   416	    }).from(images).where(inArray(images.id, ids));
   417	
   418	    // Validate all filenames before deleting anything
   419	    for (const image of imageRecords) {
   420	        if (
   421	            !isValidFilename(image.filename_original)
   422	            || !isValidFilename(image.filename_webp)
   423	            || !isValidFilename(image.filename_avif)
   424	            || !isValidFilename(image.filename_jpeg)
   425	        ) {
   426	            return { error: t('invalidFilename') };
   427	        }
   428	    }
   429	
   430	    const foundIdSet = new Set(imageRecords.map(img => img.id));
   431	    const foundIds = [...foundIdSet];
   432	    const notFoundCount = ids.filter(id => !foundIdSet.has(id)).length;
   433	
   434	    // Remove from processing queue so queue detects deletion (matches deleteImage behavior)
   435	    const queueState = getProcessingQueueState();
   436	    for (const id of foundIds) {
   437	        queueState.enqueued.delete(id);
   438	    }
   439	
   440	    // Delete DB records in a transaction (imageTags cascade via FK, but explicit for safety)
   441	    let deletedRows = 0;
   442	    if (foundIds.length > 0) {
   443	        await db.transaction(async (tx) => {
   444	            await tx.delete(imageTags).where(inArray(imageTags.imageId, foundIds));
   445	            const [deleteResult] = await tx.delete(images).where(inArray(images.id, foundIds));
   446	            deletedRows = deleteResult.affectedRows;
   447	        });
   448	    }
   449	
   450	    const staleCount = Math.max(foundIds.length - deletedRows, 0);
   451	    const currentUser = await getCurrentUser();
   452	    if (deletedRows > 0) {
   453	        logAuditEvent(currentUser?.id ?? null, 'images_batch_delete', 'image', 'batch-delete', undefined, {
   454	            requestedIds: ids,
   455	            foundIds,
   456	            requestedCount: ids.length,
   457	            deletedCount: deletedRows,
   458	            staleCount,
   459	            notFoundCount,
   460	        }).catch(console.debug);
   461	    }
   462	
   463	    // Clean up files deterministically (no readdir) for all images concurrently
   464	    // Read configured sizes to ensure all variants are cleaned up
   465	    let batchDeleteSizes: number[] | undefined;
   466	    try {
   467	        const config = await getGalleryConfig();
   468	        batchDeleteSizes = config.imageSizes.length > 0 ? config.imageSizes : undefined;
   469	    } catch {
   470	        // DB unavailable — use default sizes
   471	    }
   472	    await Promise.all(imageRecords.map(async (image) => {
   473	        try {
   474	            await Promise.all([
   475	                deleteOriginalUploadFile(image.filename_original),
   476	                deleteImageVariants(UPLOAD_DIR_WEBP, image.filename_webp, batchDeleteSizes),
   477	                deleteImageVariants(UPLOAD_DIR_AVIF, image.filename_avif, batchDeleteSizes),
   478	                deleteImageVariants(UPLOAD_DIR_JPEG, image.filename_jpeg, batchDeleteSizes),
   479	            ]);
   480	        } catch {
   481	            console.error(`Error deleting files for image ${image.id}`);
   482	        }
   483	    }));
   484	
   485	    const successCount = deletedRows;
   486	    const errorCount = notFoundCount + staleCount;
   487	
   488	    const affectedTopics = new Set(imageRecords.map(r => r.topic));
   489	
   490	    // For large batches, use layout-level revalidation to avoid ISR cache thrash
   491	    // from hundreds of individual revalidatePath calls
   492	    if (foundIds.length > 20) {
   493	        revalidateAllAppData();
   494	        revalidateLocalizedPaths('/admin/dashboard');
   495	    } else {
   496	        revalidateLocalizedPaths(
   497	            '/',
   498	            '/admin/dashboard',
   499	            ...foundIds.map(id => `/p/${id}`),
   500	            ...[...affectedTopics].map(topic => `/${topic}`)
   501	        );
   502	    }
   503	    return { success: true, count: successCount, errors: errorCount };
   504	}
