   106	    '@type': 'ImageGallery',
   107	    name: seo.title,
   108	    url: localizeUrl(baseUrl, locale, '/'),
   109	    image: images.slice(0, 10).map((img) => ({
   110	      '@type': 'ImageObject',
   111	      contentUrl: absoluteImageUrl(`/uploads/jpeg/${img.filename_jpeg}`, baseUrl),
   112	      thumbnail: absoluteImageUrl(`/uploads/jpeg/${img.filename_jpeg.replace(/\.jpg$/i, `_${findNearestImageSize(config.imageSizes, 640)}.jpg`)}`, baseUrl),
   113	      name: img.title || `Photo ${img.id}`,
   114	    })),
   115	  } : null;
   116	
   117	  return (
   118	    <>
   119	      <script
   120	        type="application/ld+json"
   121	        dangerouslySetInnerHTML={{
   122	          __html: safeJsonLd(websiteLd)
   123	        }}
   124	      />
   125	      {galleryLd && (
   126	        <script
   127	          type="application/ld+json"
   128	          dangerouslySetInnerHTML={{
   129	            __html: safeJsonLd(galleryLd)
   130	          }}
   131	        />
   132	      )}
   133	      <HomeClient images={images} tags={allTags} topics={allTopics} currentTags={tagSlugs} hasMore={hasMore} totalCount={totalCount} imageSizes={config.imageSizes} />
   134	    </>
   135	  );
   136	}

