   241	
   242	    try {
   243	        // Transaction prevents TOCTOU: image could be added between check and delete
   244	        let deletedImageFilename: string | null = null;
   245	        let deletedRows = 0;
   246	        await db.transaction(async (tx) => {
   247	            const headerImages = await tx.select({ id: images.id }).from(images).where(eq(images.topic, cleanSlug)).limit(1);
