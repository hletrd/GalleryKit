   531	        const [existingImage] = await db.select({ topic: images.topic })
   532	            .from(images).where(eq(images.id, id));
   533	
   534	        const [result] = await db.update(images)
   535	            .set({
   536	                title: sanitizedTitle,
   537	                description: sanitizedDescription,
   538	                updated_at: sql`CURRENT_TIMESTAMP`
   539	            })
   540	            .where(eq(images.id, id));
