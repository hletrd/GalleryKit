     4	/**
     5	 * Fire-and-forget audit log writer.
     6	 * Callers should use `.catch(console.debug)` to avoid blocking.
     7	 */
     8	export async function logAuditEvent(
     9	    userId: number | null,
    10	    action: string,
    11	    targetType?: string,
    12	    targetId?: string,
    13	    ip?: string,
    14	    metadata?: Record<string, unknown>,
    15	): Promise<void> {
    16	    let serializedMetadata: string | null = null;
    17	    if (metadata) {
    18	        try {
    19	            serializedMetadata = JSON.stringify(metadata);
    20	        } catch {
    21	            serializedMetadata = JSON.stringify({ note: 'metadata serialization failed' });
    22	        }
    23	
    24	        if (serializedMetadata && serializedMetadata.length > 4096) {
    25	            serializedMetadata = JSON.stringify({
    26	                truncated: true,
    27	                preview: serializedMetadata.slice(0, 4000),
    28	            });
    29	        }
    30	    }
    31	
    32	    await db.insert(auditLog).values({
    33	        userId,
    34	        action,
    35	        targetType: targetType ?? null,
    36	        targetId: targetId ?? null,
    37	        ip: ip ?? null,
    38	        metadata: serializedMetadata,
    39	    });
    40	}
    41	
    42	/**
    43	 * Purge audit log entries older than the specified age.
    44	 * Default retention: 90 days. Override with AUDIT_LOG_RETENTION_DAYS env var.
    45	 */
    46	export async function purgeOldAuditLog(maxAgeMs?: number): Promise<void> {
    47	    // Precedence: 1) explicit parameter, 2) AUDIT_LOG_RETENTION_DAYS env var, 3) default 90 days
    48	    let effectiveMaxAgeMs: number;
    49	    if (maxAgeMs !== undefined) {
    50	        effectiveMaxAgeMs = maxAgeMs;
    51	    } else {
    52	        const retentionDays = Number.parseInt(process.env.AUDIT_LOG_RETENTION_DAYS ?? '', 10) || 90;
    53	        effectiveMaxAgeMs = retentionDays * 24 * 60 * 60 * 1000;
    54	    }
    55	    const cutoff = new Date(Date.now() - effectiveMaxAgeMs);
    56	    await db.delete(auditLog).where(lt(auditLog.created_at, cutoff));
    57	}

