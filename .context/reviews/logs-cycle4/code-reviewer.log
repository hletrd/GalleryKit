   254	export async function revokePhotoShareLink(imageId: number) {
   255	    const t = await getTranslations('serverActions');
   256	    if (!(await isAdmin())) return { error: t('unauthorized') };
   257	
   258	    if (!Number.isInteger(imageId) || imageId <= 0) {
   259	        return { error: t('invalidImageId') };
   260	    }
   261	
   262	    const [image] = await db.select({ id: images.id, share_key: images.share_key }).from(images).where(eq(images.id, imageId));
   263	    if (!image) return { error: t('imageNotFound') };
   264	    if (!image.share_key) return { error: t('noActiveShareLink') };
   265	
   266	    const oldShareKey = image.share_key;
   267	
   268	    // Use conditional WHERE to prevent race with concurrent share-key recreation:
   269	    // if another admin created a new share_key between our SELECT and UPDATE,
   270	    // the conditional WHERE will match 0 rows instead of revoking the new key.
   271	    const [result] = await db.update(images)
   272	        .set({ share_key: null })
