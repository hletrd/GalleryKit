    20	
    21	import type { StorageBackend } from './types';
    22	import { LocalStorageBackend } from './local';
    23	
    24	const storageKey = Symbol.for('gallerykit.storageBackend');
    25	
    26	type StorageBackendType = 'local' | 'minio' | 's3';
    27	
    28	interface StorageState {
    29	    backend: StorageBackend;
    30	    type: StorageBackendType;
    31	    initialized: boolean;
    32	    initPromise: Promise<void> | null;
    33	}
    34	
    35	function getGlobalState(): StorageState {
    36	    const g = globalThis as typeof globalThis & { [storageKey]?: StorageState };
    37	    if (!g[storageKey]) {
    38	        const type: StorageBackendType = 'local';
    39	        g[storageKey] = {
    40	            backend: new LocalStorageBackend(),
    41	            type,
    42	            initialized: false,
    43	            initPromise: null,
    44	        };
    45	    }
    46	    return g[storageKey]!;
    47	}
