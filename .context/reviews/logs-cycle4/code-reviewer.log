    49	/**
    50	 * Get the current storage backend instance.
    51	 * Lazy-initializes on first call.
    52	 */
    53	export async function getStorage(): Promise<StorageBackend> {
    54	    const state = getGlobalState();
    55	
    56	    if (!state.initialized && !state.initPromise) {
    57	        state.initPromise = state.backend.init().then(() => {
    58	            state.initialized = true;
    59	            state.initPromise = null;
    60	        }).catch((err) => {
    61	            state.initPromise = null;
    62	            throw err;
    63	        });
    64	    }
    65	
    66	    if (state.initPromise) {
    67	        await state.initPromise;
    68	    }
    69	
    70	    return state.backend;
    71	}
