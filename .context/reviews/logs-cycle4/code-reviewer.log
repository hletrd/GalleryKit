    28	        if (!resolved.startsWith(path.resolve(UPLOAD_ROOT) + path.sep) && resolved !== path.resolve(UPLOAD_ROOT)) {
    29	            throw new Error(`Path traversal blocked: ${key}`);
    30	        }
    31	        return resolved;
    32	    }
