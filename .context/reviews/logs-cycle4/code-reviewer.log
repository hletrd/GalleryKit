   308	            }
   309	        });
   310	    } catch (e) {
   311	        if (e instanceof Error && e.message === 'GROUP_NOT_FOUND') {
   312	            return { error: t('groupNotFound') };
   313	        }
   314	        console.error('Failed to delete group share link:', e);
   315	        return { error: t('failedToDeleteGroup') };
   316	    }
   317	
   318	    revalidateLocalizedPaths('/', `/g/${group.key}`, '/admin/dashboard');
   319	    const currentUser = await getCurrentUser();
   320	    logAuditEvent(currentUser?.id ?? null, 'group_share_delete', 'shared_group', String(groupId), undefined, {
   321	        keyFingerprint: getShareKeyFingerprint(group.key),
   322	        keyLength: group.key.length,
   323	    }).catch(console.debug);
   324	    return { success: true };
   325	}

