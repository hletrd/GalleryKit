    19	
    20	const REQUIRED_DIRS = ['original', 'webp', 'avif', 'jpeg', 'resources'];
    21	
    22	export class LocalStorageBackend implements StorageBackend {
    23	    readonly name = 'local';
    24	
    25	    private resolve(key: string): string {
    26	        // Prevent path traversal: normalize and ensure result stays within UPLOAD_ROOT
