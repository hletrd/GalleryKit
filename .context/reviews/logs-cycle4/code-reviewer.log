   219	            return { error: t('failedToDeleteUser') };
   220	        }
   221	        if (e instanceof Error && e.message === 'LAST_ADMIN') {
   222	            return { error: t('cannotDeleteLastAdmin') };
   223	        }
   224	        if (e instanceof Error && e.message === 'USER_NOT_FOUND') {
   225	            return { error: t('userNotFound') };
   226	        }
