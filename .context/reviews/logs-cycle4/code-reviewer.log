     1	'use client';
     2	
     3	import { useRouter, useSearchParams, usePathname } from 'next/navigation';
     4	import { Badge } from "@/components/ui/badge"
     5	import { cn } from "@/lib/utils"
     6	
     7	import { useTranslation } from "@/components/i18n-provider";
     8	
     9	export function TagFilter({ tags }: { tags: { id: number, name: string, slug: string, count: number }[] }) {
    10	    const router = useRouter();
    11	    const pathname = usePathname();
    12	    const searchParams = useSearchParams();
    13	    const currentTagsParam = searchParams.get('tags');
    14	    const currentTags = currentTagsParam ? currentTagsParam.split(',').filter(Boolean) : [];
    15	    const { t } = useTranslation();
    16	
    17	    const handleTagClick = (slug: string | null) => {
    18	        const params = new URLSearchParams(searchParams.toString());
    19	
    20	        if (!slug) {
    21	            // Clear all tags
    22	            params.delete('tags');
    23	        } else if (currentTags.includes(slug)) {
    24	            // Remove this tag
    25	            const newTags = currentTags.filter(t => t !== slug);
    26	            if (newTags.length === 0) {
    27	                params.delete('tags');
    28	            } else {
    29	                params.set('tags', newTags.join(','));
    30	            }
    31	        } else {
    32	            // Add this tag
    33	            const newTags = [...currentTags, slug];
    34	            params.set('tags', newTags.join(','));
    35	        }
    36	
    37	        const queryString = params.toString();
    38	        router.push(`${pathname}${queryString ? `?${queryString}` : ''}`);
    39	    };
    40	
    41	    if (tags.length === 0) return null;
    42	
    43	    const handleKeyDown = (slug: string | null) => (e: React.KeyboardEvent) => {
    44	        if (e.key === 'Enter' || e.key === ' ') {
    45	            e.preventDefault();
    46	            handleTagClick(slug);
    47	        }
    48	    };
    49	
    50	    return (
    51	        <div className="flex flex-wrap gap-2" role="group" aria-label={t('home.tagFilter')}>
    52	            <Badge
    53	                asChild
    54	                variant={currentTags.length === 0 ? "default" : "outline"}
    55	                className={cn("cursor-pointer hover:bg-primary/90", currentTags.length === 0 && "bg-primary text-primary-foreground")}
    56	            >
    57	                <button
    58	                    type="button"
    59	                    onClick={() => handleTagClick(null)}
    60	                    onKeyDown={handleKeyDown(null)}
    61	                    aria-pressed={currentTags.length === 0}
    62	                >
    63	                    {t('home.allTags')}
    64	                </button>
    65	            </Badge>
    66	            {tags.map(tag => (
    67	                <Badge
    68	                    key={tag.id}
    69	                    asChild
    70	                    variant={currentTags.includes(tag.slug) ? "default" : "outline"}
    71	                    className={cn(
    72	                        "cursor-pointer hover:bg-primary/90 flex gap-1",
    73	                        currentTags.includes(tag.slug) && "bg-primary text-primary-foreground"
    74	                    )}
    75	                >
    76	                    <button
    77	                        type="button"
    78	                        onClick={() => handleTagClick(tag.slug)}
    79	                        onKeyDown={handleKeyDown(tag.slug)}
    80	                        aria-pressed={currentTags.includes(tag.slug)}
    81	                    >
    82	                        {tag.name}
    83	                        <span className="opacity-60 text-[10px]">({tag.count})</span>
    84	                    </button>
    85	                </Badge>
    86	            ))}
    87	        </div>
    88	    );
    89	}

