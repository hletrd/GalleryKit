     5	function normalizePath(path: string): string {
     6	    if (!path) return '/';
     7	    if (path === '/') return '/';
     8	    return path.startsWith('/') ? path : `/${path}`;
     9	}
    10	
    11	export function getLocalizedPathVariants(path: string): string[] {
    12	    const normalizedPath = normalizePath(path);
    13	    const segments = normalizedPath.split('/').filter(Boolean);
    14	    const firstSegment = segments[0]?.toLowerCase();
    15	
    16	    if (firstSegment && (LOCALES as readonly string[]).includes(firstSegment)) {
    17	        return [normalizedPath];
    18	    }
    19	
    20	    const variants = new Set<string>([normalizedPath]);
    21	    for (const locale of LOCALES) {
    22	        variants.add(normalizedPath === '/' ? `/${locale}` : `/${locale}${normalizedPath}`);
    23	    }
    24	
    25	    return [...variants];
    26	}
    27	
    28	// Note: This function invalidates N paths per locale (O(N*L) total where L=locale count).
    29	// With 2 locales this is manageable. If more locales are added, consider batching.
    30	export function revalidateLocalizedPaths(...paths: string[]) {
    31	    const seen = new Set<string>();
    32	
    33	    for (const path of paths) {
    34	        // Skip empty/falsy paths to avoid unnecessary root page revalidation
    35	        if (!path) continue;
    36	        for (const variant of getLocalizedPathVariants(path)) {
    37	            if (seen.has(variant)) continue;
    38	            seen.add(variant);
    39	            revalidatePath(variant);
    40	        }
    41	    }
    42	}
