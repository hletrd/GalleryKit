   113	/**
   114	 * Align a timestamp to the start of its rate-limit window.
   115	 * Returns unix seconds (not ms) aligned to the window boundary.
   116	 */
   117	export function getRateLimitBucketStart(nowMs: number, windowMs: number): number {
   118	    const windowSec = Math.floor(windowMs / 1000);
   119	    const nowSec = Math.floor(nowMs / 1000);
   120	    return nowSec - (nowSec % windowSec);
