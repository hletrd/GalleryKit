   325	    }
   326	
   327	    const isLocalDB = ['127.0.0.1', 'localhost', '::1'].includes(DB_HOST);
   328	    const restoreSslArgs = isLocalDB ? [] : ['--ssl-mode=REQUIRED'];
   329	
