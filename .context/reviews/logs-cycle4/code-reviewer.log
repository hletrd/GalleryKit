   517	    // operate on the same value that will be stored (matches settings.ts/seo.ts
   518	    // pattern, see C29-09/C30-01 and C45-03).
   519	    const sanitizedTitle = stripControlChars(title ? title.trim() : null) || null;
   520	    const sanitizedDescription = stripControlChars(description ? description.trim() : null) || null;
