   331	        // Use MYSQL_USER/MYSQL_HOST/MYSQL_TCP_PORT env vars instead of CLI flags
   332	        // to avoid exposing credentials in /proc/<pid>/cmdline
   333	        // Minimal env: HOME excluded (prevents ~/.my.cnf loading), LANG/LC_ALL
   334	        // set to C.UTF-8 for deterministic behavior regardless of server locale,
   335	        // MYSQL_* vars required for auth (avoid exposing credentials in /proc/cmdline).
   336	        const restore = spawn('mysql', [
   337	            '--one-database',
   338	            ...restoreSslArgs,
   339	            DB_NAME
   340	        ], {
   341	            env: { PATH: process.env.PATH, NODE_ENV: process.env.NODE_ENV, MYSQL_PWD: DB_PASSWORD, MYSQL_USER: DB_USER, MYSQL_HOST: DB_HOST, MYSQL_TCP_PORT: DB_PORT || '3306', LANG: 'C.UTF-8', LC_ALL: 'C.UTF-8' }
   342	        });
