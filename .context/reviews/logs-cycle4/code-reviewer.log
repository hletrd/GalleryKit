     1	'use client';
     2	
     3	import Image, { ImageProps } from 'next/image';
     4	import { useState, useRef, useEffect } from 'react';
     5	import { cn } from '@/lib/utils';
     6	import { useTranslation } from '@/components/i18n-provider';
     7	import { Loader2 } from 'lucide-react';
     8	
     9	interface OptimisticImageProps extends ImageProps {
    10	    fallbackSrc?: string;
    11	}
    12	
    13	export function OptimisticImage(props: OptimisticImageProps) {
    14	    // Force remount when src changes to reset all state cleanly
    15	    return <OptimisticImageInner key={props.src as string} {...props} />;
    16	}
    17	
    18	function OptimisticImageInner({ src, alt, className, ...props }: OptimisticImageProps) {
    19	    const { t } = useTranslation();
    20	    const [imgSrc, setImgSrc] = useState(src);
    21	    const [isLoading, setIsLoading] = useState(true);
    22	    const [error, setError] = useState(false);
    23	    const [retryCount, setRetryCount] = useState(0);
    24	    const retryTimerRef = useRef<ReturnType<typeof setTimeout>>(undefined);
    25	
    26	    // Clear retry timer on unmount
    27	    useEffect(() => () => { clearTimeout(retryTimerRef.current); }, []);
    28	
    29	    const handleError = () => {
    30	        // Stop retrying immediately if we got a definitive 404 (image doesn't exist).
    31	        // Only retry on network errors or 5xx (image may still be processing).
    32	        if (retryCount < 5) {
    33	            const delay = Math.min(500 * Math.pow(2, retryCount), 15000);
    34	            retryTimerRef.current = setTimeout(() => {
    35	                setRetryCount(c => c + 1);
    36	                const separator = typeof src === 'string' && src.includes('?') ? '&' : '?';
    37	                setImgSrc(`${src}${separator}retry=${retryCount + 1}`);
    38	            }, delay);
    39	        } else {
    40	            setError(true);
    41	            setIsLoading(false);
    42	        }
    43	    };
    44	
    45	    return (
    46	        <div className={cn("relative overflow-hidden", className)}>
    47	            <Image
    48	                {...props}
    49	                src={imgSrc}
    50	                alt={alt}
    51	                className={cn(
    52	                  "transition-opacity duration-300",
    53	                  isLoading ? "opacity-0" : "opacity-100",
    54	                  className
    55	                )}
    56	                onLoad={() => setIsLoading(false)}
    57	                onError={handleError}
    58	            />
    59	            {isLoading && (
    60	                <div className="absolute inset-0 flex items-center justify-center bg-muted/20 animate-pulse">
    61	                     <Loader2 className="h-6 w-6 animate-spin text-muted-foreground" />
    62	                </div>
    63	            )}
    64	             {error && (
    65	                <div className="absolute inset-0 flex items-center justify-center bg-muted text-muted-foreground text-xs p-2 text-center">
    66	                    {t('common.imageUnavailable')}
    67	                </div>
    68	            )}
    69	        </div>
    70	    );
    71	}

