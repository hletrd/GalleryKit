   751	// ── SEO Settings ──────────────────────────────────────────────────────────────
   752	// Reads site-wide SEO/OG settings from the `admin_settings` table.
   753	// Falls back to `site-config.json` defaults for any missing keys.
   754	// Uses React `cache()` for SSR deduplication within a single request.
   755	
   756	export interface SeoSettings {
   757	    title: string;
   758	    description: string;
   759	    nav_title: string;
   760	    author: string;
   761	    locale: string;
   762	    url: string;
   763	    og_image_url: string | null;
   764	}
   765	
   766	async function _getSeoSettings(): Promise<SeoSettings> {
   767	    let settingsMap = new Map<string, string>();
   768	    try {
   769	        // Read all SEO keys from admin_settings in a single query
   770	        const rows = await db.select({ key: adminSettings.key, value: adminSettings.value })
   771	            .from(adminSettings)
   772	            .where(inArray(adminSettings.key, [...SEO_SETTING_KEYS]));
   773	        settingsMap = new Map(rows.map(r => [r.key, r.value]));
   774	    } catch (error) {
   775	        const message = error instanceof Error ? error.message : String(error);
   776	        console.warn(`[seo] Falling back to site-config defaults because admin_settings could not be read: ${message}`);
   777	    }
   778	
   779	    return {
   780	        title: settingsMap.get('seo_title') || siteConfig.title,
   781	        description: settingsMap.get('seo_description') || siteConfig.description,
   782	        nav_title: settingsMap.get('seo_nav_title') || siteConfig.nav_title,
   783	        author: settingsMap.get('seo_author') || siteConfig.author,
   784	        locale: settingsMap.get('seo_locale') || siteConfig.locale,
   785	        url: process.env.BASE_URL || siteConfig.url,
   786	        og_image_url: settingsMap.get('seo_og_image_url') || null,
   787	    };
   788	}
   789	
   790	export const getSeoSettings = cache(_getSeoSettings);

