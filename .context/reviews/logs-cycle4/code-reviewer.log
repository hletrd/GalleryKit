     8	import { safeJsonLd } from '@/lib/safe-json-ld';
     9	import { localizePath, localizeUrl } from '@/lib/locale-path';
    10	import siteConfig from "@/site-config.json";
    11	import { getGalleryConfig } from '@/lib/gallery-config';
    12	import { findNearestImageSize } from '@/lib/gallery-config-shared';
    13	import { absoluteImageUrl } from '@/lib/image-url';
    14	
    15	const PhotoViewer = dynamic(() => import('@/components/photo-viewer'), {
    16	    loading: () => <div className="flex items-center justify-center min-h-[60vh]"><div className="animate-spin h-8 w-8 border-2 border-primary border-t-transparent rounded-full" /></div>,
    17	});
    18	
    19	
    20	// Cache for 1 week (604800s) as photo content rarely changes
    21	export const revalidate = 604800;
    22	
    23	export async function generateMetadata({ params }: { params: Promise<{ id: string }> }) {
    24	    const { id } = await params;
    25	    const locale = await getLocale();
    26	    const t = await getTranslations('photo');
    27	    const seo = await getSeoSettings();
    28	
    29	    // Validate that id is a purely numeric positive integer before parseInt
    30	    // (matches the default export's validation pattern)
    31	    if (!/^\d+$/.test(id)) {
    32	        return { title: t('notFoundTitle') };
    33	    }
    34	    const imageId = parseInt(id, 10);
    35	    if (isNaN(imageId) || imageId <= 0 || !Number.isInteger(imageId)) {
    36	        return { title: t('notFoundTitle') };
    37	    }
    38	
    39	    const image = await getImageCached(imageId);
    40	
    41	    if (!image) {
    42	        return {
    43	            title: t('notFoundTitle'),
    44	        };
    45	    }
    46	
    47	    // Safe title generation logic
    48	    const hasTags = image.tags && image.tags.length > 0;
    49	    const isTitleFilename = image.title && /\.[a-z0-9]{3,4}$/i.test(image.title);
    50	
    51	    let displayTitle = t('untitled');
    52	    let keywords: string[] = [];
    53	
    54	    if (hasTags) {
    55	        displayTitle = image.tags.map((t: TagInfo) => `#${t.name}`).join(' ');
    56	        keywords = image.tags.map((t: TagInfo) => t.name);
    57	    } else if (image.title && !isTitleFilename) {
    58	        displayTitle = image.title.split(/\s+/).map((word: string) => `#${word}`).join(' ');
    59	    } else {
    60	        displayTitle = t('titleWithId', { id: image.id });
    61	    }
    62	
    63	    if (image.topic) keywords.push(image.topic);
    64	
    65	    // Use configured image sizes for OG image URLs (avoids 404s if admin changes image_sizes)
    66	    const config = await getGalleryConfig();
    67	    const ogImageSize = findNearestImageSize(config.imageSizes, 1536);
    68	    const imageUrl = `/uploads/jpeg/${image.filename_jpeg.replace(/\.jpg$/i, `_${ogImageSize}.jpg`)}`;
    69	    const ogImageUrl = absoluteImageUrl(imageUrl, seo.url);
    70	    const pageUrl = localizeUrl(seo.url, locale, `/p/${id}`);
    71	
    72	    // Use custom OG image if configured, otherwise use photo image
    73	    const ogImages = seo.og_image_url
    74	        ? [{ url: seo.og_image_url, width: 1200, height: 630, alt: seo.title }]
    75	        : [{
    76	            url: ogImageUrl,
    77	            width: image.width,
    78	            height: image.height,
    79	            alt: displayTitle,
    80	        }];
    81	
    82	    return {
    83	        title: displayTitle,
    84	        description: image.description || t('descriptionByAuthorWithTitle', { author: seo.author, title: displayTitle }),
    85	        keywords: keywords,
    86	        alternates: {
    87	            canonical: pageUrl,
    88	        },
    89	        openGraph: {
    90	            title: displayTitle,
    91	            description: image.description || t('descriptionByAuthor', { author: seo.author }),
    92	            url: pageUrl,
    93	            siteName: seo.title,
    94	            images: ogImages,
    95	            type: 'article',
    96	            publishedTime: image.created_at?.toString(),
    97	            authors: [seo.author],
    98	        },
    99	        twitter: {
   100	            card: 'summary_large_image',
   101	            title: displayTitle,
   102	            description: image.description || t('descriptionByAuthor', { author: seo.author }),
   103	            images: seo.og_image_url ? [seo.og_image_url] : [ogImageUrl],
   104	        }
   105	    };
   106	}
   107	
   108	export default async function PhotoPage({ params }: { params: Promise<{ id: string }> }) {
   109	    const { id } = await params;
   110	    const locale = await getLocale();
   111	    const t = await getTranslations('photo');
   112	
   113	    // Validate that id is a purely numeric positive integer
   114	    if (!/^\d+$/.test(id)) {
   115	        return notFound();
   116	    }
   117	    const imageId = parseInt(id, 10);
   118	    if (isNaN(imageId) || imageId <= 0 || !Number.isInteger(imageId)) {
   119	        return notFound();
   120	    }
   121	
   122	    const image = await getImageCached(imageId);
   123	
   124	    if (!image) return notFound();
   125	
   126	    const seo = await getSeoSettings();
   127	    const config = await getGalleryConfig();
   128	
   129	    // Replicate title logic for JSON-LD
   130	    const hasTags = image.tags && image.tags.length > 0;
   131	    const isTitleFilename = image.title && /\.[a-z0-9]{3,4}$/i.test(image.title);
   132	
   133	    const displayTitle = hasTags
   134	        ? image.tags.map((t: TagInfo) => `#${t.name}`).join(' ')
   135	        : (image.title && !isTitleFilename
   136	            ? image.title.split(/\s+/).map((word: string) => `#${word}`).join(' ')
   137	            : t('untitled'));
   138	
   139	    const keywords = image.tags?.map((t: TagInfo) => t.name) || [];
   140	    if (image.topic) keywords.push(image.topic);
   141	
   142	    const jsonLd = {
   143	        '@context': 'https://schema.org',
   144	        '@type': 'ImageObject',
   145	        contentUrl: absoluteImageUrl(`/uploads/jpeg/${image.filename_jpeg}`, seo.url),
   146	        thumbnailUrl: absoluteImageUrl(`/uploads/jpeg/${image.filename_jpeg.replace(/\.jpg$/i, `_${findNearestImageSize(config.imageSizes, 640)}.jpg`)}`, seo.url),
   147	        encodingFormat: 'image/jpeg',
   148	        license: 'https://creativecommons.org/licenses/by-nc/4.0/',
   149	        acquireLicensePage: siteConfig.parent_url,
   150	        creditText: seo.author,
   151	        creator: {
   152	            '@type': 'Person',
   153	            name: seo.author,
   154	        },
   155	        copyrightNotice: seo.author,
   156	        datePublished: image.created_at,
   157	        uploadDate: image.created_at,
   158	        width: {
   159	            '@type': 'QuantitativeValue',
   160	            value: image.width,
   161	            unitCode: 'E37',
   162	        },
   163	        height: {
   164	            '@type': 'QuantitativeValue',
   165	            value: image.height,
   166	            unitCode: 'E37',
   167	        },
   168	        name: displayTitle,
   169	        description: image.description,
   170	        keywords: keywords.join(', '),
   171	        // GPS coordinates are intentionally excluded from public queries for privacy
   172	        exifData: [
   173	            image.camera_model && { '@type': 'PropertyValue', name: 'Camera', value: image.camera_model },
   174	            image.lens_model && { '@type': 'PropertyValue', name: 'Lens', value: image.lens_model },
   175	            image.iso && { '@type': 'PropertyValue', name: 'ISO', value: image.iso },
   176	            image.f_number && { '@type': 'PropertyValue', name: 'Aperture', value: `f/${image.f_number}` },
   177	            image.exposure_time && { '@type': 'PropertyValue', name: 'Exposure Time', value: `${image.exposure_time}s` },
   178	        ].filter(Boolean),
   179	    };
   180	
   181	    const breadcrumbLd = {
   182	        '@context': 'https://schema.org',
   183	        '@type': 'BreadcrumbList',
   184	        itemListElement: [
   185	            {
   186	                '@type': 'ListItem',
   187	                position: 1,
   188	                name: seo.title || siteConfig.title,
   189	                item: localizeUrl(seo.url, locale, '/'),
   190	            },
   191	            image.topic && {
   192	                '@type': 'ListItem',
   193	                position: 2,
   194	                name: image.topic,
   195	                item: localizeUrl(seo.url, locale, `/${image.topic}`),
   196	            },
   197	            {
   198	                '@type': 'ListItem',
   199	                position: image.topic ? 3 : 2,
   200	                name: displayTitle,
   201	                item: localizeUrl(seo.url, locale, `/p/${id}`),
   202	            },
   203	        ].filter(Boolean),
   204	    };
   205	
   206	    const isAdminUser = await isAdmin();
   207	
   208	    return (
   209	        <>
   210	            <script
   211	                type="application/ld+json"
   212	                dangerouslySetInnerHTML={{
   213	                    __html: safeJsonLd(jsonLd)
   214	                }}
   215	            />
   216	            <script
   217	                type="application/ld+json"
   218	                dangerouslySetInnerHTML={{
   219	                    __html: safeJsonLd(breadcrumbLd)
   220	                }}
   221	            />
   222	            <PhotoViewer
   223	                images={[image]}
   224	                initialImageId={image.id}
   225	                tags={image.tags ?? []}
   226	                prevId={image.prevId}
   227	                nextId={image.nextId}
   228	                canShare={isAdminUser}
   229	                isAdmin={isAdminUser}
   230	                imageSizes={config.imageSizes}
   231	                siteTitle={seo.title}
   232	            />
   233	            {/* Prefetch adjacent photos for instant navigation */}
   234	            {image.prevId && (
   235	                <Link href={localizePath(locale, `/p/${image.prevId}`)} prefetch={true} className="hidden" aria-hidden="true" tabIndex={-1}>
   236	                    prev
   237	                </Link>
   238	            )}
   239	            {image.nextId && (
   240	                <Link href={localizePath(locale, `/p/${image.nextId}`)} prefetch={true} className="hidden" aria-hidden="true" tabIndex={-1}>
   241	                    next
   242	                </Link>
   243	            )}
   244	        </>
   245	    );
   246	}

