    11	
    12	import { db, adminSettings } from '@/db';
    13	import { inArray } from 'drizzle-orm';
    14	import { cache } from 'react';
    15	
    16	// Re-export shared constants, types, and validators for server-side consumers
    17	export {
    18	    GALLERY_SETTING_KEYS,
    19	    type GallerySettingKey,
    20	    isValidSettingValue,
    21	    getSettingDefaults,
    22	    parseImageSizes,
    23	} from './gallery-config-shared';
    24	
    25	import { GALLERY_SETTING_KEYS, getSettingDefaults, isValidSettingValue, parseImageSizes } from './gallery-config-shared';
    26	import type { GallerySettingKey } from './gallery-config-shared';
    27	
    28	// ── Defaults (imported from shared module to avoid duplication) ────────────────
    29	const DEFAULTS = getSettingDefaults();
    30	
    31	// ── Typed Getters ─────────────────────────────────────────────────────────────
    32	
    33	async function getSettingsMap(): Promise<Map<string, string>> {
    34	    const rows = await db.select({ key: adminSettings.key, value: adminSettings.value })
    35	        .from(adminSettings)
    36	        .where(inArray(adminSettings.key, [...GALLERY_SETTING_KEYS]));
    37	
    38	    return new Map(rows.map(r => [r.key, r.value]));
    39	}
    40	
    41	function getSetting(map: Map<string, string>, key: GallerySettingKey): string {
    42	    return map.get(key) || DEFAULTS[key];
    43	}
    44	
    45	// ── Cached Config Interface ───────────────────────────────────────────────────
    46	
    47	export interface GalleryConfig {
    48	    // Image Processing
    49	    imageQualityWebp: number;
    50	    imageQualityAvif: number;
    51	    imageQualityJpeg: number;
    52	    imageSizes: number[];
    53	
    54	    // Privacy
    55	    stripGpsOnUpload: boolean;
    56	}
    57	
    58	/**
    59	 * Parse a numeric setting with validation and fallback.
    60	 * If the DB value is corrupted or invalid, falls back to the default.
    61	 */
    62	function validatedNumber(map: Map<string, string>, key: GallerySettingKey): number {
    63	    const raw = getSetting(map, key);
    64	    if (!isValidSettingValue(key, raw)) return Number(DEFAULTS[key]);
    65	    return Number(raw);
    66	}
    67	
    68	async function _getGalleryConfig(): Promise<GalleryConfig> {
    69	    const map = await getSettingsMap();
    70	
    71	    // Use parseImageSizes for sorted output and invalid-input fallback (C13-01)
    72	    const imageSizes = parseImageSizes(getSetting(map, 'image_sizes'));
    73	
    74	    return {
    75	        imageQualityWebp: validatedNumber(map, 'image_quality_webp'),
    76	        imageQualityAvif: validatedNumber(map, 'image_quality_avif'),
    77	        imageQualityJpeg: validatedNumber(map, 'image_quality_jpeg'),
    78	        imageSizes,
    79	        stripGpsOnUpload: (() => {
    80	            const raw = getSetting(map, 'strip_gps_on_upload');
    81	            if (!isValidSettingValue('strip_gps_on_upload', raw)) return DEFAULTS.strip_gps_on_upload === 'true';
    82	            return raw === 'true';
    83	        })(),
    84	    };
    85	}
    86	
    87	/** Cached gallery config — deduped within a single SSR request via React cache(). */
    88	export const getGalleryConfig = cache(_getGalleryConfig);

