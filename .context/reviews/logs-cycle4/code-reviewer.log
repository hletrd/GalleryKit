    89	                console.error(`[Storage:${this.name}] Failed to create bucket ${this.bucket}:`, createErr);
    90	                throw createErr;
    91	            }
    92	        }
    93	    }
    94	
    95	    async writeStream(key: string, stream: Readable | import('stream/web').ReadableStream, contentType?: string): Promise<StorageWriteResult> {
    96	        // S3 PutObject requires the full body; collect from stream
    97	        const chunks: Uint8Array[] = [];
    98	        const nodeStream = 'pipe' in stream
    99	            ? stream as Readable
   100	            : await import('stream').then(({ Readable: R }) => R.fromWeb(stream as import('stream/web').ReadableStream));
   101	
   102	        for await (const chunk of nodeStream) {
   103	            chunks.push(typeof chunk === 'string' ? Buffer.from(chunk) : chunk);
   104	        }
   105	        const body = Buffer.concat(chunks);
   106	
   107	        await this.client.send(new PutObjectCommand({
   108	            Bucket: this.bucket,
   109	            Key: key,
   110	            Body: body,
   111	            ContentType: contentType,
   112	        }));
   113	
   114	        return { key, size: body.length };
   115	    }
   116	
   117	    async writeBuffer(key: string, data: Buffer, contentType?: string): Promise<StorageWriteResult> {
   118	        await this.client.send(new PutObjectCommand({
   119	            Bucket: this.bucket,
   120	            Key: key,
   121	            Body: data,
   122	            ContentType: contentType,
   123	        }));
   124	
   125	        return { key, size: data.length };
   126	    }
   127	
   128	    async readBuffer(key: string): Promise<Buffer> {
   129	        const response = await this.client.send(new GetObjectCommand({
   130	            Bucket: this.bucket,
   131	            Key: key,
   132	        }));
   133	
   134	        if (!response.Body) throw new Error(`Empty response for key: ${key}`);
   135	
   136	        // Collect stream into buffer
   137	        const chunks: Uint8Array[] = [];
   138	        for await (const chunk of response.Body as AsyncIterable<Uint8Array>) {
   139	            chunks.push(chunk);
   140	        }
   141	        return Buffer.concat(chunks);
   142	    }
   143	
   144	    async createReadStream(key: string): Promise<Readable> {
   145	        const response = await this.client.send(new GetObjectCommand({
   146	            Bucket: this.bucket,
   147	            Key: key,
   148	        }));
   149	
   150	        if (!response.Body) throw new Error(`Empty response for key: ${key}`);
   151	
   152	        // AWS SDK returns a web ReadableStream; convert to Node Readable
   153	        const { Readable } = await import('stream');
   154	        return Readable.fromWeb(response.Body as unknown as import('stream/web').ReadableStream);
   155	    }
   156	
   157	    async stat(key: string): Promise<StorageObjectInfo> {
   158	        try {
   159	            const result = await this.client.send(new HeadObjectCommand({
   160	                Bucket: this.bucket,
   161	                Key: key,
   162	            }));
   163	            return { exists: true, size: result.ContentLength };
   164	        } catch (err: unknown) {
   165	            if (err instanceof Error && err.name === 'NotFound') {
   166	                return { exists: false };
   167	            }
   168	            if (err instanceof Error && '$metadata' in err && (err as { $metadata: { httpStatusCode?: number } }).$metadata.httpStatusCode === 404) {
   169	                return { exists: false };
   170	            }
   171	            throw err;
   172	        }
   173	    }
   174	
   175	    async delete(key: string): Promise<void> {
   176	        await this.client.send(new DeleteObjectCommand({
   177	            Bucket: this.bucket,
   178	            Key: key,
   179	        })).catch(() => {});
   180	    }
   181	
   182	    async deleteMany(keys: string[]): Promise<void> {
   183	        // S3 supports batch delete but individual deletes in parallel are simpler
   184	        // and sufficient for gallery workloads (usually <10 files per image)
   185	        await Promise.all(keys.map(k => this.delete(k)));
   186	    }
   187	
   188	    async copy(srcKey: string, destKey: string): Promise<void> {
   189	        await this.client.send(new CopyObjectCommand({
   190	            Bucket: this.bucket,
   191	            Key: destKey,
   192	            CopySource: `${this.bucket}/${srcKey}`,
   193	        }));
   194	    }
   195	
   196	    async getUrl(key: string, options?: PresignedUrlOptions): Promise<string> {
   197	        // If a public URL base is configured, use direct access
   198	        if (this.publicUrl) {
   199	            const base = this.publicUrl.replace(/\/+$/, '');
   200	            return `${base}/${key}`;
   201	        }
   202	
   203	        // Otherwise generate a presigned URL
   204	        const expiresIn = options?.expiresIn || 3600;
   205	        const command = new GetObjectCommand({
   206	            Bucket: this.bucket,
   207	            Key: key,
   208	            ...(options?.contentType && { ResponseContentType: options.contentType }),
   209	        });
   210	
   211	        return getSignedUrl(this.client, command, { expiresIn });
   212	    }
   213	
   214	    async dispose(): Promise<void> {
   215	        this.client.destroy();
   216	    }
   217	}

