    18	export async function generateMetadata({ params, searchParams }: { params: Promise<{ topic: string }>, searchParams: Promise<{ tags?: string }> }): Promise<Metadata> {
    19	  const { topic } = await params;
    20	  const { tags: tagsParam } = await searchParams;
    21	  const locale = await getLocale();
    22	  const t = await getTranslations('topic');
    23	  const seo = await getSeoSettings();
    24	
    25	  const topicData = await getTopicBySlugCached(topic);
    26	
    27	  if (!topicData) return {
    28	    title: t('notFoundTitle'),
    29	    description: t('notFoundDescription'),
    30	  };
    31	
    32	  const allTags = await getTags(topicData.slug);
    33	  const tagSlugs = filterExistingTagSlugs(parseRequestedTagSlugs(tagsParam), allTags);
    34	
    35	  const title = tagSlugs.length > 0
    36	    ? `${tagSlugs.map(t => '#' + t).join(' ')} | ${topicData.label}`
    37	    : topicData.label;
    38	
    39	  const description = tagSlugs.length > 0
    40	    ? t('browsePhotosWithTag', { tags: tagSlugs.join(', '), topic: topicData.label })
    41	    : t('photosInTopic', { topic: topicData.label });
    42	
    43	  const pageUrl = localizeUrl(seo.url, locale, `/${topicData.slug}`);
    44	
    45	  // Use custom OG image if configured, otherwise use generated OG image
    46	  const topicOgParams = new URLSearchParams({ topic: topicData.slug });
    47	  if (tagSlugs.length > 0) {
    48	    topicOgParams.set('tags', tagSlugs.join(','));
    49	  }
    50	  topicOgParams.set('label', topicData.label);
    51	  topicOgParams.set('site', seo.title || siteConfig.title);
    52	
    53	  const ogImages = seo.og_image_url
    54	    ? [{ url: seo.og_image_url, width: 1200, height: 630, alt: title }]
    55	    : [{
