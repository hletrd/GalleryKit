     1	/**
     2	 * Storage Backend Interface
     3	 *
     4	 * Abstract interface for file storage operations. All gallery storage
     5	 * goes through this interface so the backend (local, MinIO, S3) can
     6	 * be swapped via admin settings without changing business logic.
     7	 *
     8	 * Key conventions:
     9	 * - `key` is a relative path like `original/abc.jpg` or `webp/abc.webp`
    10	 * - Backends handle their own prefix/bucket mapping internally
    11	 * - Local backend keys map to `UPLOAD_ROOT/<key>`
    12	 * - S3/MinIO backend keys map to `<bucket>/<key>`
    13	 */
    14	
    15	import type { Readable } from 'stream';
    16	
    17	/** Metadata returned when writing a file. */
    18	export interface StorageWriteResult {
    19	    /** The storage key where the file was written. */
    20	    key: string;
    21	    /** Size in bytes (if known). */
    22	    size?: number;
    23	}
    24	
    25	/** Info about a stored object. */
    26	export interface StorageObjectInfo {
    27	    /** Whether the object exists. */
    28	    exists: boolean;
    29	    /** Size in bytes. */
    30	    size?: number;
    31	}
    32	
    33	/** Parameters for creating a presigned URL (S3/MinIO only). */
    34	export interface PresignedUrlOptions {
    35	    /** How long the URL is valid, in seconds. Default: 3600 */
    36	    expiresIn?: number;
    37	    /** Response content-type override. */
    38	    contentType?: string;
    39	}
    40	
    41	export interface StorageBackend {
    42	    /** Human-readable name for logging. */
    43	    readonly name: string;
    44	
    45	    /** Ensure the storage is ready (create buckets, dirs, etc.). Called once on startup. */
    46	    init(): Promise<void>;
    47	
    48	    /**
    49	     * Write a file from a Node.js Readable stream.
    50	     * Used for upload pipeline (original files from browser).
    51	     */
    52	    writeStream(key: string, stream: Readable | import('stream/web').ReadableStream, contentType?: string): Promise<StorageWriteResult>;
    53	
    54	    /**
    55	     * Write a file from a Buffer.
    56	     * Used by Sharp output pipeline.
    57	     */
    58	    writeBuffer(key: string, data: Buffer, contentType?: string): Promise<StorageWriteResult>;
    59	
    60	    /**
    61	     * Read a file as a Buffer.
    62	     * Used for verification and small file access.
    63	     */
    64	    readBuffer(key: string): Promise<Buffer>;
    65	
    66	    /**
    67	     * Create a readable stream for a file.
    68	     * Used by serve-upload.ts for streaming responses.
    69	     */
    70	    createReadStream(key: string): Promise<Readable>;
    71	
    72	    /**
    73	     * Check if a file exists and get its metadata.
    74	     */
    75	    stat(key: string): Promise<StorageObjectInfo>;
    76	
    77	    /**
    78	     * Delete a single file. Silently succeed if not found.
    79	     */
    80	    delete(key: string): Promise<void>;
    81	
    82	    /**
    83	     * Delete multiple files in parallel. Silently succeed for missing files.
    84	     */
    85	    deleteMany(keys: string[]): Promise<void>;
    86	
    87	    /**
    88	     * Copy a file within the same backend.
    89	     * Used by Sharp pipeline for hardlink-equivalent behavior.
    90	     */
    91	    copy(srcKey: string, destKey: string): Promise<void>;
    92	
    93	    /**
    94	     * Get a public or presigned URL for a file.
    95	     * For local backend this returns a relative path like `/uploads/jpeg/foo.jpg`.
    96	     * For S3/MinIO this returns a presigned URL or public URL.
    97	     */
    98	    getUrl(key: string, options?: PresignedUrlOptions): Promise<string>;
    99	
   100	    /**
   101	     * Clean up resources (connections, etc.).
   102	     */
   103	    dispose?(): Promise<void>;
   104	}

