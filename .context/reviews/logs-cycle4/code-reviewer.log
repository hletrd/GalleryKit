   320	    const { DB_HOST, DB_USER, DB_PASSWORD, DB_NAME, DB_PORT } = process.env;
   321	
   322	    if (!DB_HOST || !DB_USER || !DB_PASSWORD || !DB_NAME) {
   323	        await fs.unlink(tempPath).catch(() => {});
