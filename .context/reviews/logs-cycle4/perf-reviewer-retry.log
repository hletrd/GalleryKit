                                        <Histogram
                                            imageUrl={imageUrl(`/uploads/jpeg/${image.filename_jpeg?.replace(/\.jpg$/i, `_${findNearestImageSize(imageSizes, 640)}.jpg`)}`)}
                                            className="w-full"
