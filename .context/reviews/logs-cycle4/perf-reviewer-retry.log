    if (addTagNames.length > 100 || removeTagNames.length > 100) {
        return { success: false, added: 0, removed: 0, warnings: [t('tooManyTags')] };
    }

    const warnings: string[] = [];
    let added = 0;
    let removed = 0;

    try {
        await db.transaction(async (tx) => {
