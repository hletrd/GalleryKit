                                        </a>
                                    </Button>
                                )}
                            </CardFooter>
                        </Card>
                    )}
                </div>
            </div>

            {showLightbox && (
                <Lightbox
                    image={image}
                    prevId={prevId ?? (images[currentIndex - 1]?.id || null)}
                    nextId={nextId ?? (images[currentIndex + 1]?.id || null)}
                    onClose={() => setShowLightbox(false)}
                    onNavigate={navigate}
                    imageSizes={imageSizes}
                />
            )}

            <InfoBottomSheet
                image={image}
                isOpen={showBottomSheet}
                onClose={() => setShowBottomSheet(false)}
                isAdmin={isAdmin}
            />
        </div>
    );
}

