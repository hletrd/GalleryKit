                    </Button>
                    )}

                    <Button
                        variant={isPinned ? "default" : "outline"}
                        size="sm"
                        onClick={() => {
                            if (isPinned) {
                                setIsPinned(false);
                                setTimerShowInfo(false);
                            } else {
                                setIsPinned(true);
