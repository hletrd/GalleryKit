                    }}
                  >
                    #{tag}
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      ),
      {
        width: 1200,
        height: 630,
        headers: {
            'Cache-Control': cacheControl,
        }
      },
    );
  } catch (e: unknown) {
    if (e instanceof Error) {
        console.error(`${e.message}`);
    }
    return new Response(`Failed to generate the image`, {
      status: 500,
      headers: {
        'Cache-Control': 'public, max-age=60',
      },
    });
  }
}

