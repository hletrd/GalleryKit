                            </p>
                            {formattedCaptureTime && (
                                <p className="font-medium flex items-center gap-1 text-xs text-muted-foreground mt-1" suppressHydrationWarning>
                                    <Clock className="w-3 h-3" />
                                    {formattedCaptureTime}
                                </p>
                            )}
                        </div>
                    </div>
                )}
            </div>
            </FocusTrap>
        </>
    );
}

