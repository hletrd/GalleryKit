                  maxWidth: '800px',
                }}
              >
                {tagList.map((tag) => (
                  <div
                    key={tag}
                    style={{
                      fontSize: '32px',
                      padding: '8px 24px',
                      backgroundColor: '#27272a', // zinc-800
