     1	/**
     2	 * Upload Path Constants
     3	 *
     4	 * Single source of truth for all upload directory paths.
     5	 * Previously duplicated in process-image.ts, storage/local.ts, and serve-upload.ts.
     6	 */
     7	
     8	import path from 'path';
     9	import fs from 'fs/promises';
    10	
    11	/** Root directory for all uploaded files. Derived from UPLOAD_ROOT env var or cwd. */
    12	export const UPLOAD_ROOT = (() => {
    13	    const envRoot = process.env.UPLOAD_ROOT?.trim();
    14	    if (envRoot) return envRoot;
    15	
    16	    const monorepoPath = path.join(process.cwd(), 'apps/web/public/uploads');
    17	    const simplePath = path.join(process.cwd(), 'public/uploads');
    18	    if (process.cwd().endsWith('apps/web')) {
    19	        return simplePath;
    20	    }
    21	    return monorepoPath;
    22	})();
    23	
    24	/** Legacy directory where original uploads used to live under the public web root. */
    25	export const LEGACY_UPLOAD_DIR_ORIGINAL = path.join(UPLOAD_ROOT, 'original');
    26	/** Private directory for original uploads. Derived from UPLOAD_ORIGINAL_ROOT env var or cwd. */
    27	export const UPLOAD_ORIGINAL_ROOT = (() => {
    28	    const envRoot = process.env.UPLOAD_ORIGINAL_ROOT?.trim();
    29	    if (envRoot) return envRoot;
    30	
    31	    const monorepoPath = path.join(process.cwd(), 'apps/web/data/uploads/original');
    32	    const simplePath = path.join(process.cwd(), 'data/uploads/original');
    33	    if (process.cwd().endsWith('apps/web')) {
    34	        return simplePath;
    35	    }
    36	    return monorepoPath;
    37	})();
    38	
    39	/** Directory for original uploaded files. */
    40	export const UPLOAD_DIR_ORIGINAL = UPLOAD_ORIGINAL_ROOT;
    41	/** Directory for processed WebP files. */
    42	export const UPLOAD_DIR_WEBP = path.join(UPLOAD_ROOT, 'webp');
    43	/** Directory for processed AVIF files. */
    44	export const UPLOAD_DIR_AVIF = path.join(UPLOAD_ROOT, 'avif');
    45	/** Directory for processed JPEG files. */
    46	export const UPLOAD_DIR_JPEG = path.join(UPLOAD_ROOT, 'jpeg');
    47	
    48	export async function resolveOriginalUploadPath(filename: string) {
    49	    const candidates = [
    50	        path.join(UPLOAD_DIR_ORIGINAL, filename),
    51	        path.join(LEGACY_UPLOAD_DIR_ORIGINAL, filename),
    52	    ];
    53	
    54	    for (const candidate of candidates) {
    55	        try {
    56	            await fs.access(candidate);
    57	            return candidate;
    58	        } catch {
    59	            continue;
    60	        }
    61	    }
    62	
    63	    return candidates[0];
    64	}
    65	
    66	export async function deleteOriginalUploadFile(filename: string) {
    67	    await Promise.all([
    68	        fs.unlink(path.join(UPLOAD_DIR_ORIGINAL, filename)).catch(() => {}),
    69	        fs.unlink(path.join(LEGACY_UPLOAD_DIR_ORIGINAL, filename)).catch(() => {}),
    70	    ]);
    71	}
    72	
    73	export async function assertNoLegacyPublicOriginalUploads(options: { failInProduction?: boolean } = {}) {
    74	    let fileCount = 0;
    75	    try {
    76	        const entries = await fs.readdir(LEGACY_UPLOAD_DIR_ORIGINAL, { withFileTypes: true });
    77	        fileCount = entries.filter((entry) => entry.isFile()).length;
    78	    } catch (error) {
    79	        if ((error as NodeJS.ErrnoException).code === 'ENOENT') {
    80	            return;
    81	        }
    82	        throw error;
    83	    }
    84	    if (fileCount === 0) {
    85	        return;
    86	    }
    87	
    88	    const message = `Found ${fileCount} legacy original upload(s) in ${LEGACY_UPLOAD_DIR_ORIGINAL}. Move originals to ${UPLOAD_DIR_ORIGINAL} before serving traffic.`;
    89	    if (options.failInProduction && process.env.NODE_ENV === 'production') {
    90	        throw new Error(message);
    91	    }
    92	
    93	    console.warn(`[uploads] ${message}`);
    94	}

