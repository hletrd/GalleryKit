   181	 * Get the current backend status (type and initialization state).
   182	 * Useful for admin UI to display storage health.
   183	 */
   184	export function getStorageBackendStatus(): { type: StorageBackendType; initialized: boolean } {
   185	    const state = getGlobalState();
   186	    return { type: state.type, initialized: state.initialized };
   187	}
   188	
   189	/**
   190	 * Get the current backend type.
   191	 */
   192	export function getStorageBackendType(): StorageBackendType {
   193	    return getGlobalState().type;
