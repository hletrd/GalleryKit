    92	
    93	        return new NextResponse(webStream, {
    94	            headers: {
    95	                'Content-Type': contentType,
    96	                'Content-Length': stats.size.toString(),
    97	                'Cache-Control': 'public, max-age=31536000, immutable',
    98	                'X-Content-Type-Options': 'nosniff',
    99	            },
   100	        });
   101	
   102	    } catch (err: unknown) {
   103	        // Clean up stream on error
   104	        if (fileStream) {
   105	            fileStream.destroy();
   106	        }
   107	        if (err instanceof Error && 'code' in err && (err as NodeJS.ErrnoException).code === 'ENOENT') {
   108	            return new NextResponse('File not found', { status: 404 });
   109	        }
   110	        console.error('Error serving static file:', err);
   111	        return new NextResponse('Internal Server Error', { status: 500 });
   112	    }
   113	}

