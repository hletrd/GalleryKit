    35	export async function updateGallerySettings(settings: Record<string, string>) {
    36	    const t = await getTranslations('serverActions');
    37	    if (!(await isAdmin())) return { error: t('unauthorized') };
    38	    const defaults = getSettingDefaults();
    39	
    40	    // Validate all provided keys are allowed
    41	    const allowedKeys = new Set<string>(GALLERY_SETTING_KEYS);
    42	    for (const key of Object.keys(settings)) {
    43	        if (!allowedKeys.has(key)) {
    44	            return { error: t('invalidSettingKey') };
    45	        }
    46	    }
    47	
    48	    // Sanitize before validation so length/format checks operate on the same
    49	    // value that will be stored. Without this, control characters pass
    50	    // validation but are stripped later, causing a mismatch between validated
    51	    // and persisted data (same pattern as seo.ts C29-09 fix).
    52	    const sanitizedSettings: Record<string, string> = {};
    53	    for (const [key, value] of Object.entries(settings)) {
    54	        sanitizedSettings[key] = stripControlChars(value.trim()) ?? '';
    55	    }
    56	
    57	    // Validate individual setting values (on sanitized values)
    58	    for (const [key, value] of Object.entries(sanitizedSettings)) {
    59	        if (!value) continue; // Empty means "use default" — will be deleted
    60	        if (!isValidSettingValue(key as GallerySettingKey, value)) {
    61	            return { error: t('invalidSettingValue', { key }) };
    62	        }
    63	    }
    64	
    65	    if (Object.prototype.hasOwnProperty.call(sanitizedSettings, 'image_sizes')) {
    66	        const requestedImageSizes = sanitizedSettings.image_sizes;
    67	        const normalizedImageSizes = requestedImageSizes
    68	            ? normalizeConfiguredImageSizes(requestedImageSizes)
    69	            : defaults.image_sizes;
    70	        if (!normalizedImageSizes) {
    71	            return { error: t('invalidSettingValue', { key: 'image_sizes' }) };
    72	        }
    73	        if (requestedImageSizes) {
    74	            sanitizedSettings.image_sizes = normalizedImageSizes;
    75	        }
    76	
    77	        const [currentImageSizesSetting] = await db
    78	            .select({ value: adminSettings.value })
    79	            .from(adminSettings)
    80	            .where(eq(adminSettings.key, 'image_sizes'))
    81	            .limit(1);
    82	
    83	        const currentImageSizes = normalizeConfiguredImageSizes(currentImageSizesSetting?.value ?? defaults.image_sizes)
    84	            ?? defaults.image_sizes;
    85	
