   101	        await db.transaction(async (tx) => {
   102	            for (const [key, value] of Object.entries(sanitizedSettings)) {
   103	                if (!value) {
   104	                    // Delete empty settings so defaults take effect
   105	                    await tx.delete(adminSettings).where(eq(adminSettings.key, key));
   106	                } else {
