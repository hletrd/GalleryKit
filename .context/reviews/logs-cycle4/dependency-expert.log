--- root package deploy helper ---
     1	#!/usr/bin/env bash
     2	set -euo pipefail
     3	
     4	ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
     5	ENV_FILE="${DEPLOY_ENV_FILE:-$ROOT_DIR/.env.deploy}"
     6	
     7	expand_tilde_path() {
     8	  local value="${1:-}"
     9	  if [[ "$value" == "~" ]]; then
    10	    printf '%s\n' "$HOME"
    11	    return
    12	  fi
    13	
    14	  if [[ "$value" == "~/"* ]]; then
    15	    printf '%s/%s\n' "$HOME" "${value#~/}"
    16	    return
    17	  fi
    18	
    19	  printf '%s\n' "$value"
    20	}
    21	
    22	build_deploy_command() {
    23	  local host="${DEPLOY_HOST:-}"
    24	  local user="${DEPLOY_USER:-}"
    25	  local path="${DEPLOY_PATH:-}"
    26	  local key="${DEPLOY_KEY:-}"
    27	  local remote_script="${DEPLOY_REMOTE_SCRIPT:-bash apps/web/deploy.sh}"
    28	
    29	  : "${host:?Missing DEPLOY_HOST in $ENV_FILE}"
    30	  : "${user:?Missing DEPLOY_USER in $ENV_FILE}"
    31	  : "${path:?Missing DEPLOY_PATH in $ENV_FILE}"
    32	
    33	  local remote_cmd
    34	  printf -v remote_cmd 'cd %q && %s' "$path" "$remote_script"
    35	
    36	  local -a command=(ssh)
    37	  if [[ -n "$key" ]]; then
    38	    key="$(expand_tilde_path "$key")"
    39	    command+=(-i "$key")
    40	  fi
    41	
    42	  command+=("${user}@${host}" "$remote_cmd")
    43	  printf '%q ' "${command[@]}"
    44	}
    45	
    46	if [[ ! -f "$ENV_FILE" ]]; then
    47	  echo "Missing deploy env file: $ENV_FILE" >&2
    48	  echo "Copy .env.deploy.example to .env.deploy and customize DEPLOY_HOST / DEPLOY_USER / DEPLOY_PATH (or DEPLOY_CMD) first." >&2
    49	  exit 1
    50	fi
    51	
    52	set -a
    53	# shellcheck disable=SC1090
    54	source "$ENV_FILE"
    55	set +a
    56	
    57	deploy_cmd="${DEPLOY_CMD:-}"
    58	if [[ -z "$deploy_cmd" ]]; then
    59	  deploy_cmd="$(build_deploy_command)"
    60	fi
    61	
    62	echo "[deploy] Running deploy command from $ENV_FILE"
    63	exec bash -lc "$deploy_cmd"

