    10	import { localizeUrl } from '@/lib/locale-path';
    11	
    12	const BASE_URL = process.env.BASE_URL || siteConfig.url;
    13	
    14	// Google recommends max 50,000 URLs per sitemap file.
    15	// With 2 locales, cap images at 24,000 to stay well under the limit
    16	// (24,000 * 2 locales + homepage + topics = ~48,000).
    17	const MAX_SITEMAP_IMAGES = 24000;
    18	
    19	export default async function sitemap(): Promise<MetadataRoute.Sitemap> {
    20	  const [images, topics] = await Promise.all([
    21	    getImageIdsForSitemap(MAX_SITEMAP_IMAGES),
    22	    getTopics(),
    23	  ]);
    24	
    25	  const homepageEntries: MetadataRoute.Sitemap = LOCALES.map((locale) => ({
    26	    url: localizeUrl(BASE_URL, locale, '/'),
    27	    lastModified: new Date(),
    28	    changeFrequency: 'daily',
    29	    priority: 1,
    30	  }));
    31	
    32	  const topicEntries: MetadataRoute.Sitemap = topics.flatMap((topic) =>
    33	    LOCALES.map((locale) => ({
    34	      url: localizeUrl(BASE_URL, locale, `/${topic.slug}`),
    35	      lastModified: new Date(),
    36	      changeFrequency: 'weekly' as const,
    37	      priority: 0.8,
    38	    }))
    39	  );
    40	
    41	  // DB query already caps at MAX_SITEMAP_IMAGES — no slice needed
    42	  const imageEntries: MetadataRoute.Sitemap = images.flatMap((image) =>
    43	    LOCALES.map((locale) => ({
    44	      url: localizeUrl(BASE_URL, locale, `/p/${image.id}`),
    45	      lastModified: new Date(image.created_at || Date.now()),
    46	      changeFrequency: 'weekly' as const,
    47	      priority: 0.7,
    48	    }))
    49	  );
    50	
    51	  return [
    52	    ...homepageEntries,
    53	    ...topicEntries,
