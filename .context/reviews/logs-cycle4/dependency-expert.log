    28	/**
    29	 * Shared handler for serving uploaded image files with security checks.
    30	 * Used by both /uploads/[...path] and /[locale]/uploads/[...path] routes.
    31	 */
    32	export async function serveUploadFile(pathSegments: string[]): Promise<NextResponse> {
    33	    if (!Array.isArray(pathSegments) || pathSegments.length < 2) {
    34	        return new NextResponse('Not found', { status: 404 });
    35	    }
    36	
    37	    const [topLevelDir] = pathSegments;
    38	    if (!ALLOWED_UPLOAD_DIRS.has(topLevelDir)) {
    39	        return new NextResponse('Not found', { status: 404 });
    40	    }
    41	
    42	    // Validate file extension matches the directory — prevents serving
    43	    // mismatched files (e.g., a .webp from /uploads/jpeg/).
    44	    const filename = pathSegments[pathSegments.length - 1];
    45	    const ext = path.extname(filename).toLowerCase();
    46	    const allowedExts = DIR_EXTENSION_MAP[topLevelDir];
    47	    if (allowedExts && !allowedExts.has(ext)) {
    48	        return new NextResponse('Invalid path', { status: 400 });
    49	    }
    50	
    51	    // Content type is resolved from the extension already extracted above
    52	    const contentType = CONTENT_TYPES[ext];
    53	
    54	    for (const segment of pathSegments) {
    55	        if (!segment || segment.length > MAX_SEGMENT_LENGTH || segment === '.' || segment === '..') {
    56	            return new NextResponse('Invalid path', { status: 400 });
    57	        }
    58	        if (!SAFE_SEGMENT.test(segment)) {
    59	            return new NextResponse('Invalid path', { status: 400 });
    60	        }
    61	    }
    62	
