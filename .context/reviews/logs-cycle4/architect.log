FROM node:24-slim AS base

# Install system dependencies needed for sharp and better-sqlite3 + gosu
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    gosu \
    mariadb-client \
    && rm -rf /var/lib/apt/lists/*

FROM base AS deps
WORKDIR /app

# Copy package.json and lock file from monorepo root
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/

# Install dependencies (including devDependencies for build)
RUN npm ci --workspace=apps/web

FROM base AS prod-deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
RUN npm ci --omit=dev --workspace=apps/web

FROM base AS builder
WORKDIR /app
# Full node_modules for build step (includes devDependencies needed by next build)
COPY --from=deps /app/node_modules ./node_modules
COPY . .

WORKDIR /app/apps/web
# Use real site-config.json if present in build context, otherwise fall back to example
RUN if [ ! -f src/site-config.json ]; then cp src/site-config.example.json src/site-config.json; fi

# Build the app
RUN npm run build

FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
# Disable next.js telemetry
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV UPLOAD_ORIGINAL_ROOT="/app/data/uploads/original"

# Copy necessary files from apps/web (public is mounted at runtime)
COPY --from=builder --chown=node:node /app/apps/web/.next/standalone ./
COPY --from=builder --chown=node:node /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=node:node /app/apps/web/drizzle ./apps/web/drizzle
COPY --from=builder --chown=node:node /app/apps/web/scripts/migrate.js ./apps/web/scripts/migrate.js
COPY --from=builder --chown=node:node /app/apps/web/scripts/mysql-connection-options.js ./apps/web/scripts/mysql-connection-options.js
COPY --chown=node:node apps/web/scripts/entrypoint.sh /usr/local/bin/

# Production dependencies for migrate.js (needs argon2, mysql2, drizzle-orm natively).
# Standalone output already bundles runtime deps — this is only for the migration script.
COPY --from=prod-deps --chown=node:node /app/node_modules ./node_modules

# Create persistence directories and cache
RUN mkdir -p apps/web/public/uploads /app/data/uploads/original apps/web/.next/cache && chown -R node:node apps/web/public/uploads /app/data apps/web/.next

# Make entrypoint executable
RUN chmod +x /usr/local/bin/entrypoint.sh

# Health check — verifies the app is responsive and DB is reachable
HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD node -e "fetch('http://localhost:3000/api/health').then(r=>r.ok?process.exit(0):process.exit(1)).catch(()=>process.exit(1))"

# Expose port
EXPOSE 3000

# Use entrypoint to handle permissions/user switching
ENTRYPOINT ["entrypoint.sh"]

# Start command
CMD ["sh", "-c", "node apps/web/scripts/migrate.js && node apps/web/server.js"]

---COMPOSE---
services:

  web:
    build:
      context: ../..
      dockerfile: apps/web/Dockerfile
    container_name: gallerykit-web
    restart: always
    stop_grace_period: 30s
    # Use host networking so the container can reach MySQL on 127.0.0.1.
    # Nginx reverse proxy on the host handles rate limiting and security headers.
    network_mode: host
    env_file:
      - .env.local
    environment:
      HOSTNAME: 127.0.0.1
      TRUST_PROXY: "true"

    volumes:
      - ./data:/app/data
      - ./public:/app/apps/web/public
      - ./src/site-config.json:/app/apps/web/src/site-config.json:ro

---ENTRYPOINT---
#!/bin/sh
set -e

# Fix permissions on data directory only if not already owned by node
if [ "$(stat -c '%U' /app/data 2>/dev/null || echo root)" != "node" ]; then
    chown -R node:node /app/data
fi
if [ "$(stat -c '%U' /app/apps/web/public/uploads 2>/dev/null || echo root)" != "node" ]; then
    chown -R node:node /app/apps/web/public/uploads
fi

# Ensure .next folder exists and has correct permissions
# Create cache directory explicitly to avoid runtime EACCES
# Ensure .next/cache exists (Next.js needs this to be writable)
mkdir -p /app/apps/web/.next/cache

# Fix permissions for the entire .next directory
# This is crucial because standard COPY commands might leave some files as root
# or the cache directory created above constitutes a new permission requirement
if [ -d "/app/apps/web/.next" ]; then
    chown -R node:node /app/apps/web/.next
fi

# Set UV_THREADPOOL_SIZE to CPU count if not set
if [ -z "$UV_THREADPOOL_SIZE" ]; then
    if command -v nproc > /dev/null; then
        export UV_THREADPOOL_SIZE=$(nproc)
    else
        export UV_THREADPOOL_SIZE=4
    fi
    echo "Auto-configured UV_THREADPOOL_SIZE=$UV_THREADPOOL_SIZE"
fi

# Drop privileges and execute command
exec gosu node "$@"

---NGINX---
# Rate limiting zones (per-IP, shared memory)
limit_req_zone $binary_remote_addr zone=login:10m rate=10r/m;
limit_req_zone $binary_remote_addr zone=admin:10m rate=30r/m;
limit_conn_zone $binary_remote_addr zone=connlimit:10m;

# Upstream with keepalive to avoid per-request TCP handshakes
upstream nextjs {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    server_name gallery.atik.kr;

    client_max_body_size 10G;
    client_body_timeout 60s;
    send_timeout 30s;

    # Limit concurrent connections per IP
    limit_conn connlimit 20;

    server_tokens off;

    # Compression
    gzip on;
    gzip_comp_level 5;
    gzip_min_length 256;
    gzip_types text/html text/css application/javascript application/json image/svg+xml text/plain;
    gzip_vary on;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    # CSP for proxied responses is set by Next.js (single source of truth).
    # Only the static image location below has its own tighter CSP.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    proxy_hide_header X-Powered-By;

    # Rate-limit POST to admin login page (both with and without locale prefix)
    location ~ ^(/[a-z]{2})?/admin$ {
        limit_req zone=login burst=5 nodelay;
        limit_req_status 429;

        proxy_pass http://nextjs;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Rate-limit admin mutation routes (uploads, DB backup/restore, user management)
    location ~ ^(/[a-z]{2})?/admin/(dashboard|db|categories|tags|users|password) {
        limit_req zone=admin burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://nextjs;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /uploads/original/ {
        return 404;
    }

    # Serve uploaded images directly via nginx (sendfile) — avoids Node.js entirely.
    # Restricts to known format dirs (jpeg/webp/avif) and image extensions only.
    # Uses root + rewrite (not alias) for reliability with regex locations.
    location ~ ^(?:/[a-z]{2})?/uploads/(jpeg|webp|avif)/.+\.(?:jpe?g|webp|avif|png)$ {
        root /app/apps/web/public;
        # Strip optional locale prefix: /en/uploads/... → /uploads/...
        rewrite ^(?:/[a-z]{2})?(/uploads/.*)$ $1 break;

        expires 1y;
        add_header Cache-Control "public, immutable";
        # Repeat all security headers — nginx add_header does NOT inherit from parent block
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
        add_header Content-Security-Policy "default-src 'none'; img-src 'self'; style-src 'none'; script-src 'none';" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    }

    location / {
        proxy_pass http://nextjs;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "";  # Enable keepalive (empty = no close)
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 10s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;
    }
