@tailwind base;
@tailwind components;
@tailwind utilities;

@font-face {
    font-family: 'Pretendard';
    src: url('/fonts/PretendardVariable.woff2?v=1') format('woff2');
    font-weight: 45 920;
    font-style: normal;
    font-display: swap;
}

@layer base {
  :root {
    --font-heading: "Pretendard", "Inter", sans-serif;
    --font-body: "Pretendard", "Inter", sans-serif;

    --background: 0 0% 100%;
    --foreground: 240 10% 3.9%;
    --card: 0 0% 100%;
    --card-foreground: 240 10% 3.9%;
    --popover: 0 0% 100%;
    --popover-foreground: 240 10% 3.9%;
    --primary: 240 5.9% 10%;
    --primary-foreground: 0 0% 98%;
    --secondary: 240 4.8% 95.9%;
    --secondary-foreground: 240 5.9% 10%;
    --muted: 240 4.8% 95.9%;
    --muted-foreground: 240 3.8% 46.1%;
    --accent: 240 4.8% 95.9%;
    --accent-foreground: 240 5.9% 10%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 0 0% 98%;
    --border: 240 5.9% 90%;
    --input: 240 5.9% 90%;
    --ring: 240 5.9% 10%;
    --radius: 0.5rem;
  }

  .dark {
    --background: 240 10% 3.9%;
    --foreground: 0 0% 98%;
    --card: 240 10% 3.9%;
    --card-foreground: 0 0% 98%;
    --popover: 240 10% 3.9%;
    --popover-foreground: 0 0% 98%;
    --primary: 0 0% 98%;
    --primary-foreground: 240 5.9% 10%;
    --secondary: 240 3.7% 15.9%;
    --secondary-foreground: 0 0% 98%;
    --muted: 240 3.7% 15.9%;
    --muted-foreground: 240 5% 64.9%;
    --accent: 240 3.7% 15.9%;
    --accent-foreground: 0 0% 98%;
    --destructive: 0 62.8% 30.6%;
    --destructive-foreground: 0 0% 98%;
    --border: 240 3.7% 15.9%;
    --input: 240 3.7% 15.9%;
    --ring: 240 4.9% 83.9%;
  }
}

@layer base {
  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground;
    font-family: "Pretendard", "Inter", sans-serif;
  }
}

@layer utilities {
  .mask-gradient-right {
    mask-image: linear-gradient(to right, black 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 80%, transparent 100%);
  }
  .mask-none {
    mask-image: none;
    -webkit-mask-image: none;
  }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton-shimmer {
  position: relative;
  overflow: hidden;
}

.skeleton-shimmer::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 25%, rgba(255,255,255,0.06) 50%, transparent 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  pointer-events: none;
}

/* Color gamut detection */
:root { --display-gamut: srgb; }
@media (color-gamut: p3) { :root { --display-gamut: p3; } }
@media (dynamic-range: high) { :root { --display-hdr: true; } }

/* Only show P3 badge on P3-capable displays */
.gamut-p3-badge { display: none; }
@media (color-gamut: p3) { .gamut-p3-badge { display: inline-block; } }

/* Orientation-aware layout: landscape mobile */
@media (orientation: landscape) and (max-width: 767px) {
  .photo-viewer-image {
    max-height: 100vh;
  }
  .photo-viewer-toolbar {
    display: none;
  }
  .photo-viewer-container {
    min-height: 100vh;
    padding: 0;
  }
  .masonry-grid {
    columns: 2;
  }
}

/* Orientation-aware layout: landscape tablet */
@media (orientation: landscape) and (min-width: 768px) and (max-width: 1023px) {
  .photo-viewer-grid {
    grid-template-columns: 1fr 300px;
  }
}

/* Scrollbar hiding utility — used by nav horizontal scroll on mobile */
@layer utilities {
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
}

/* Virtual masonry: skip layout/paint for offscreen cards.
   contain-intrinsic-size is set per-card via inline style using actual aspect ratio. */
.masonry-card {
