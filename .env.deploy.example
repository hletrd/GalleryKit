# Gitignored remote deploy configuration.
# Copy this file to .env.deploy and customize it for your target.

# Preferred mode: let npm run deploy derive the SSH command from these fields.
DEPLOY_HOST=example.com
DEPLOY_USER=deploy-user
DEPLOY_KEY=~/.ssh/example.pem
DEPLOY_PATH=/srv/gallery
DEPLOY_REMOTE_SCRIPT=bash apps/web/deploy.sh

# Optional escape hatch: override the derived SSH command entirely.
# DEPLOY_CMD=ssh -i ~/.ssh/example.pem deploy-user@example.com "cd /srv/gallery && bash apps/web/deploy.sh"
