# Gitignored remote deploy configuration.
# Copy this file to .env.deploy and customize it for your target.

DEPLOY_HOST=gallery.atik.kr
DEPLOY_USER=ubuntu
DEPLOY_KEY=~/.ssh/atik.pem
DEPLOY_PATH=/home/ubuntu/gallery
DEPLOY_CMD=ssh -i ~/.ssh/atik.pem ubuntu@gallery.atik.kr "cd /home/ubuntu/gallery && bash apps/web/deploy.sh"
